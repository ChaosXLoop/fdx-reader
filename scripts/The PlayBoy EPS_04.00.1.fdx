<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="6">

  <DocumentRef DateTime="20260307T230129" id="5efceb66-2e1a-44b0-b53d-d6b0fd6bf4d0">
    <XRef DateTime="19691231T155959" id="31eebf07-025b-4252-816e-1747d15525b1"/>
  </DocumentRef>

  <Content>
    <Paragraph Type="Transition" id="4477578d-f8f5-4232-8a5f-3b25b2a3f08d">
      <Text>COLD OPEN</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="b1582ffe-c17e-4c36-8baa-4c74618a24d2">
      <SceneProperties Length="1" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DENNIS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WAWA EMPLOYEE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>BLACK SCREEN.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1d3154e2-a2b6-417a-a6e5-9d22d4615406">
      <Text>The sound of a commercial coffee machine. The specific industrial shuffle of a Gas station counter at predawn.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6d7751d6-75ee-46e4-ac30-2b3855e6ca38">
      <Text>WAWA EMPLOYEE (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7035eab6-51a4-455b-9ced-ae817adc8b94">
      <Text>(genuinely pleasant)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a64a5cfe-ae1f-4d2a-8265-7c9fe036e685">
      <Text>Morning! What can I get started for you?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0081c3da-e2b5-4b33-a4ae-5cfc80d2d8ab">
      <Text>DENNIS (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e588efdc-3c13-486e-8c97-8f8ae8d9de26">
      <Text>Large coffee. Black.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0421c18c-09df-4f11-b5ed-7853cf7fb666">
      <Text>WAWA EMPLOYEE (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c8ceffef-eb20-4092-85ce-b9b862925b47">
      <Text>You got it. Rough morning?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b6f12154-1cbb-4c71-bd4b-ad8ace4e8193">
      <Text>DENNIS (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="6330d9eb-7a92-483b-bb02-82271e70419c">
      <Text>(a beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b7356882-66f3-4fff-8c15-b1484e0e40c5">
      <Text>What?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b5a25fe6-5da6-4f95-bef5-c0ac4fe44f76">
      <Text>WAWA EMPLOYEE (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1390084b-9b45-47cd-851f-c351713aad8e">
      <Text>Just— you're beating the dawn rush.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="65b2cd0b-a9c4-40b9-991a-5c4e7176bec7">
      <Text>DENNIS (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="8d3b30cc-9455-4464-801d-4978f0e1c819">
      <Text>(grumpy)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4f855c6b-f951-4939-ba6b-2c671d824c20">
      <Text>I'm always in early.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="972c4c16-36fd-413f-aaa4-77a7ff99ac00">
      <Text>WAWA EMPLOYEE (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c9fef63a-df90-4cfb-8273-eb90bbbecdee">
      <Text>Oh nice, early bird. I respect that. I've been here since four so—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="54daabae-7a77-4f2c-9555-8968d5fa0b23">
      <Text>DENNIS (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8409255f-0dcc-4ea7-95ff-5e53006218be">
      <Text>Why would I care- How long on the coffee?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="db953b5a-42e1-4afb-887a-5d47c5c0c571">
      <Text>A beat. The machine hisses. The sound of a lid being pressed onto a cup.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e1198393-0978-4554-af7b-14b778abe7c7">
      <Text>WAWA EMPLOYEE (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="c5a6e38b-16c4-42ff-81a3-44d9427b89e0">
      <Text>(strained professional)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fdcd001a-cce3-4de9-a703-5a53b4056810">
      <Text>Right- here. That's four twenty-nine. Have a great—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d4be9416-8e2a-47a0-80a1-8027da5b083c">
      <Text>DENNIS (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2f4c87ea-5747-4db9-8675-13f50233b326">
      <Text>Don’t patronize me.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4907f643-1390-4eef-a1ba-9d49ada98ba6">
      <Text>The sound of a door.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="b2ef438f-415b-42a9-a88f-c42da070efb0">
      <Text>SMASH CUT TO:</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c0291bcf-db1c-42b1-b1b6-b87c75ecfdd1">
      <Text>TITLE CARD: THE PLAYBOY</Text>
    </Paragraph>
    <Paragraph Type="Action" id="37956061-8104-46ba-9324-6ad5c4e96f1d">
      <Text>"First Inspection"</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="1e4a4d1c-8fc1-44af-b29e-2f0f9b4ad281">
      <SceneProperties Length="3/8" Page="2" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. ROUTE 515 - VERNON TOWNSHIP - DAWN</Text>
    </Paragraph>
    <Paragraph Type="Action" id="503b78b3-de74-4e58-bc29-772474ed5002">
      <Text>Magic hour. The tree line catching first light in the upper branches— orange, amber— the low places still dark and fogged.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="77b8b1b6-f3c6-4d4a-9e3b-9cf70ca0fd89">
      <Text>A 2019 CHEVROLET MALIBU moves through it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="19a60638-b400-4feb-8e47-8044f9987b13">
      <Text>State fleet gray. A crease in the passenger panel that starts above the wheel well and dies at the door seam. The rear driver's side hubcap is a different manufacturer than the other three.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="c571bc44-88f5-4c01-b90b-a1a02a2b5ee2">
      <SceneProperties Length="5/8" Page="2" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. Pruitt Malibu - cONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b9682c04-31cb-431c-b8ef-dfa8e69e4aef">
      <Text>DENNIS PRUITT behind the wheel. Sussex County Pretrial Services polo, freshly pressed. Reading glasses on. A WAWA 20 </Text>
      <Text AdornmentStyle="-1">ouncer</Text>
      <Text> in the cupholder, the lid tab still up— untouched. On the passenger seat: a Sudoku book, closed, a pen clipped to the cover.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="aaf32308-e57c-4b67-ac59-07c823751a01">
      <Text>On the dash: a clipboard. NJ-PTS Form 14A. INITIAL ON-SITE COMPLIANCE INSPECTION. Both McCort names at the top. He doesn't need to glance at it, but he does anyway.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="339611ff-a056-42e2-a11a-9ce3f8c0968b">
      <Text>He turns off Route 515 onto the private drive.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="95c9cf75-a847-481c-a928-7bacbeabe02d">
      <Text>The Malibu moves through the trees. The canopy closes over the road, the drive curving, the building invisible until—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d0a19e9a-bf6c-4dc3-9018-dd709960a547">
      <Text>It isn't.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8b249636-8603-4124-8ec6-f63f86e204eb">
      <Text>Dennis's foot comes off the accelerator unconsciously as the grandeur sinks in a little.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d1c04de8-8647-4d6d-8a75-d4750a29bf51">
      <Text>The building through the windshield. The full scope of it, eight stories, both wings, the grand facade catching the sunrise straight on. Gold on the river rock. The copper roofline accents throwing it back. The lobby glass holding the entire pink-orange sky in its face like a mirror.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e513cd27-caf9-4bf2-9f98-1c349603b31d">
      <Text>He sits in the idling Malibu and looks at it.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="78e12daf-07ce-416f-8ca1-d4ae96a3eacc">
      <SceneProperties Length="1" Page="2" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. PLAYBOY RESORT - MAIN ENTRANCE - mOMENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e3143bcf-4def-4456-963a-ae20613a5773">
      <Text>The Malibu pulls up under the porte-cochère. Dennis steps out, clipboard under his arm, coffee in hand. He walks to the lobby entrance.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="28309521-dd8e-433d-b906-574cafe3b7e7">
      <Text>The revolving door: full-height glass and chrome, blocked from the inside. Two horizontal two-by-fours wedged across the drum, cross-braced against the interior frame. Someone sealed the primary entrance of the place years ago and long since forgot about it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a6a0922e-1223-4828-9669-ad3db48442b2">
      <Text>Dennis pushes. Quarter-inch. Stops. Tries the other direction. Same.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0ad79d0a-0746-4e36-a96b-01e44f23587b">
      <Text>He steps back. Looks at the door. Looks at the floor-to-ceiling glass panels flanking it— a decade of film and particulate, opaque as frosted glass.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3a45894e-56d4-4920-98b0-70aa087b3875">
      <Text>He raises his palm. Clears a circle. Leans in.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="facfc58b-1df5-4506-8305-7c96017e0ae7">
      <Text>The copper fireplace looms three stories high of oxidized metal catching the last of the night. The hearth’s gas fire still burning through the small hours of the morning.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="be3a49f0-b23b-4951-a979-17cb098ba127">
      <Text>HUNTER in the armchair. His mouth open at slack angle. A blanket around his shoulders, disheveled. Breathing loudly enough to be visible.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4951c97e-c4ad-4dfe-b0e4-530dafe0e814">
      <Text>JAMIE on the hearth platform. Hoodie down over his face. Burrs still on his sleeves from last night.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a9f21828-1872-4aa3-98b4-20ec8896bb6f">
      <Text>KEVIN against the reception desk against the wood paneling. Legs extended. Blanket across them. Ankle monitor catching the firelight on his left leg. Green pulse. Compliant.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a72b6307-671c-4bab-b481-cd33540db875">
      <Text>Dennis straightens up after taking in this macabre scene. He sets his coffee on the ground, careful, level.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="15d96134-50be-4951-8cd9-1832ed96c75d">
      <Text>He makes a fist.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2b1aa447-dbe1-44db-ac3b-f4b66233e534">
      <Text>KNOCK. KNOCK. KNOCK.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="75c76498-7c9f-4d12-9bbe-7793b2a5a6e9">
      <Text>Official. Three times. A knock of authority.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3aad2283-2df9-4fa0-b0d5-dacf68b17d6a">
      <Text>Nothing stirs.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d7f4dcf1-1a04-44cd-b837-2fa3169da37b">
      <Text>KNOCK. KNOCK. KNOCK.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7e09cc6c-6a32-4ca2-bb76-54323ef49692">
      <Text>Harder. His knuckles on glass.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="e4d152f4-3ec3-4adf-b6de-285785cc5066">
      <SceneProperties Length="11 1/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DENNIS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="HUNTER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JANET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JAZ">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEVIN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT - LOBBY - CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="05b01b2c-dc48-4eea-aae8-93767ad05aa0">
      <Text>The sound bouncing off stone floor and copper wall and three stories of atrium.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="633cd0d8-867b-43a7-9cf3-a95c004557a9">
      <Text>Hunter's head comes off his arm. Rises. Drops. Rises. His eyes not opening.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="65090919-7db7-430d-92e2-5abb4ead8908">
      <Text>Kevin shifts. Blanket falling. His head comes up— Confused as to where he is before he remembers.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2ed014c8-03f2-4709-a639-7b2f2222042c">
      <Text>Jamie's already awake. Checking the time.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a942608a-bbac-41c2-8b77-ca83333700ba">
      <Text>KNOCK. KNOCK. KNOCK.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3d2adfe3-7dae-432d-bdb3-2ab79dff8ddd">
      <Text>Louder.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b496d22f-d767-47ed-bf5f-a2ae505aba1b">
      <Text>Hunter snap to his feet. Blanket falling. Standing in yesterday's shirt, looking at the front door. his only fully formed thought so far is: Oh no, I’m still alive.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3ff046f1-ba9e-4545-8586-5048ff823d05">
      <Text>Kevin moves toward the desk. Looking for something by instinct— whatever that might be in an abandoned hotel lobby when someone is at the boarded up door.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="76b05cbd-7d0a-4044-bead-e77e16be8e90">
      <Text>KNOCK. KNOCK. KNOCK.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a49ed8e5-1f2b-43ac-93e1-85ba8ba187cc">
      <Text>Hunter finds the cleared lens Dennis made in the glass. Puts his face to it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fa8b1e72-25b2-4c80-a28a-fc044e12449c">
      <Text>Six inches away on the other side— Dennis Pruitt's face, looking back.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c887237e-1f6f-474e-8260-c1569d1dd441">
      <Text>Dennis raises the ID badge. Sussex County Pretrial Services. The laminated card. The official seal. His ID photograph from 2021, seven pounds lighter.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f185bdbc-cf9d-401f-a5aa-2b4c6a73f9d3">
      <Text>Hunter stares at it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ba89e17f-7e44-4cbb-986d-2cb9431019d7">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="1fc80076-49f6-405a-a661-d32280c854f2">
      <Text>(to no one)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0358b46a-4d28-430d-96e2-676e21d3da53">
      <Text>Yeah.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="c8afab49-8e2b-4854-9e1b-da14bce052f9">
      <Text>(turns)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="59af0a5e-0dd0-4b6d-937c-63f58373e2f0">
      <Text>Kevin?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e0d86462-95d8-404e-b5a1-c19125737726">
      <Text>Kevin is already there.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="76de5136-edf2-4a7e-80a0-3b2c6721f768">
      <Text>He looks through the lens at the man holding the badge. He straightens. The COO composure assembles itself— at 6:47 in the morning with an ankle monitor blinking green.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1b3294c4-3ae9-4e41-b0e7-e0b5f2bd5c84">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="65b969ba-a299-43d5-8119-2398d9f345a4">
      <Text>How do we open this.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="67f40e7d-f7e2-4c3b-8444-7184edadbf6d">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="6a1b797d-73e9-41b0-a310-fb2ce11c8f87">
      <Text>(looking at the braced revolving door)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="30fa0f0b-0072-4393-a46b-8ded614d3e70">
      <Text>I have no idea.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="02b6796f-b7c9-42e7-8b3a-85e96258a6c1">
      <Text>Behind them, boots on stone. Jaz rounds the corner from the east hall. Blanket over her shoulders.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="77681b45-85b2-4ddd-8b93-b48166558b73">
      <Text>She reads the room in one look. Dennis at the glass. Hunter and Kevin at the door. Jamie on the platform.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a29c7cb7-3661-42c5-9c48-c30191aacd76">
      <Text>She steps to the revolving door. Finds the access panel set into the glass wall beside the drum. Flips the bolt. Pushes it open.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9a217ba4-495d-4049-82eb-a0e63c4ff7d0">
      <Text>The dawn air comes through. Cold. The smell of the drive and the trees.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="24bb125d-b54b-476f-94ec-77442d92fb14">
      <Text>Dennis Pruitt steps inside.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="54d5b42f-5849-4576-9f0c-61a0903f19f0">
      <Text>He looks at the lobby. The copper fireplace. The atrium climbing above him. The balconies. The ferns trailing from dead planters on every tier. He takes it in.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0de81649-a392-484d-ba4e-8dc6fe6a1d41">
      <Text>Then he finds Kevin.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6ba56493-a8a7-411d-93f8-43e3417fb945">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="55f272ad-d9bb-4fff-a08f-724f61cca4d6">
      <Text>(completely warm)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f5110f46-bf7b-433c-bdfc-f8ebe9da782e">
      <Text>Mr. McCort, I presume. Dennis Pruitt, Sussex County Pretrial Services.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="14c69e14-3092-47d9-a4e4-d1e44cfe1df2">
      <Text>He extends his hand.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="39a5f9b9-3d20-441c-a7ee-ad320db496c4">
      <Text>Kevin holds just long enough to register the pause. Short enough to not be a refusal. Then, he shakes it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3e828550-82f4-4215-aeb8-e00b21e784d7">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7bf6aad0-f330-4bf3-a525-a495ac1eb3de">
      <Text>Hope I didn't wake you too early.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8a89e61b-ffc4-4e26-8506-620eeb2d1c78">
      <Text>Hunter has located his legal pad on the floor beside the armchair. He retrieves it. Straightens. His hair is doing something architectural on one side. He smooths it. It does not cooperate.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="26286e4b-6124-4de5-8b99-fd7b4609c54a">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="0ed7fe6a-e197-44ab-8deb-446654679c38">
      <Text>(to Hunter condescendingly)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="49ee2d36-6637-471d-a7eb-73e86ebc5a2e">
      <Text>You must be the- lawyer.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3e572857-5168-4440-b122-60edb770a275">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="36f7c656-4f32-4366-94ee-fe54bbe6d3b5">
      <Text>(very even)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8521bbb6-3790-4375-834b-1ef7ae54bec2">
      <Text>Hunter Reid. Counsel of record for Mr. McCort.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9e336009-6f6d-4dca-aff0-707b319520d2">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="28710cdb-17e4-4d75-8b1a-b74233b5a9f6">
      <Text>(nodding)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8129936e-b68e-4a7f-aa73-9039667d9d88">
      <Text>Reid. Right.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5a2addf8-fbbe-426f-be65-423627c63c35">
      <Text>Hunter watches him make a small notation on the clipboard. Neither of their faces move.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="155629cc-4232-4460-8351-fc42760b4ca9">
      <Text>Dennis caps his pen. Looks at the room. At Jamie on the hearth platform. At Jaz in the hall doorway with her blanket.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2b7d251b-422b-4981-a05a-7b347dbaa4a9">
      <Text>His clipboard comes up again.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="77877870-3326-4487-be1f-14b32c76ec46">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="050970fd-0986-4604-bded-28078fb09d9a">
      <Text>So. Let's just— get acquainted. Get everyone on the same page. I find that if we establish expectations early, we all have a much more productive relationship going forward. I want this to be— collegial. I genuinely do.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3d84cccc-3860-487a-835b-c345e3d83e14">
      <Text>He says collegial like someone who learned it recently and has been waiting to use it in a sentence.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="81d7a07c-2e02-477f-8db8-c5ae3e4d3d4a">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="49b460e2-714d-4849-b13f-2ca02c3e0fa1">
      <Text>You're going to find that I am not the enemy here. I am a resource. I am here to support your successful completion of the conditions of your pretrial release, and I take that responsibility- Very- Seriously.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="dc9688e3-5657-413f-97ae-278517e9a3b3">
      <Text>(beat, to Kevin)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eb45dac9-bdb6-4101-b7ce-45c1e3ec82bb">
      <Text>Now I've reviewed your file thoroughly, Mr. McCort, and I want you to know that I don't make assumptions. I don't prejudge. What I do is establish a framework of compliance that allows you to show the court that you are a trustworthy member of this—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8c3457e2-a848-4a06-a940-53338fad440f">
      <Text>He looks at the lobby again.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cbf5f990-3459-43d5-ba4b-67533c2a881d">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7e580e19-84c6-4f04-b69e-7a5c0e14cfec">
      <Text>—community. Going forward.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="78b0bd1a-fea4-426b-a6bb-978bc2fd380e">
      <Text>Hunter is writing something on his legal pad. Dennis clocks this.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="81794316-1a11-4ddf-b802-f8d6ee5782f3">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="504d140c-1772-46e2-b7e4-29a90a54fd4c">
      <Text>You don't need to take notes, Mr. Reid. I'll be providing written documentation of today's inspection for your records. That's standard.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cba8103c-0c8f-48b5-9778-84bd78807e72">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7f4cb4e5-38eb-4a3c-96b3-56c4d7d8f37d">
      <Text>I like notes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9f33e020-eaa7-46da-85d7-35b6e742cdf6">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="39dd83ab-b70d-43a9-85e0-989c17586fce">
      <Text>(the smile)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="19ebbc91-1cd6-4225-aa71-84d2439bcfd4">
      <Text>Of course you do.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2145e4d0-3331-4ddd-9cc3-de6fa37ee5a1">
      <Text>He looks back at Kevin. The clipboard comes up again.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="78dfd590-9dbe-4b0b-b2d0-0e0f9083355e">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4bc27416-c354-42c4-adc3-b8b54e1aac2e">
      <Text>Now. In terms of that framework. Contact restrictions, location parameters, electronic device disclosure— we're going to go through all of that for absolute clarity. Because Mr. McCort, and I say this as someone who genuinely wants to see you succeed—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2079ff38-6559-41ef-8d98-266ec2622af1">
      <Text>He leans in. Fractionally. Just enough.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c1f2bdea-c33f-429e-a747-b3a1379a576d">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="05d41437-5194-434d-bcaa-5cdd6fa47184">
      <Text>The parameters exist for a reason. They are not suggestions. They are not— starting points for a negotiation. And I have found, in my twenty years of doing this work, that the individuals who do best are the ones who understand, right from the jump, that the moment I detect— and I will detect— any deviation, any irregularity, any—</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e3d82ab5-e96c-4069-9f28-7991be68a1fe">
      <Text>(a small pause, he sniffs)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4c58d8aa-bf90-4ba9-81cc-bcc6e4a9d12a">
      <Text>-fragrance of non-compliance? I don't deliberate. I don't give second chances. I pick up the phone and you are back inside before your attorney has had the opportunity to even locate his legal pad.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4e96783a-fe5d-4d93-a6f3-4176f6269bd3">
      <Text>He says it directly at Hunter as he looks up from his notes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b9933da9-415e-430d-8dd0-4f3af594b472">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7f2735f4-ba8a-4605-a7f9-23edf1f4be39">
      <Text>But we're not going to get there. And this is going to be— Collegial.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="5a6e4294-c49d-4644-b790-1d79963c7052">
      <Text>(back to the clipboard)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="555b1399-03a6-4a28-aac3-bbc26aa052d9">
      <Text>Now. Devices. I'm going to need all phones, laptops, tablets- connected devices on property disclosed and registered this morning. Passwords provided. That's everyone in the household.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="aeec3751-b430-4965-b3ab-6a81855b3508">
      <Text>He looks past Hunter to Jamie on the hearth, and Jaz in the doorway. He looks back at the file.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1a99ae42-6df3-435d-95fc-d305a86d5db9">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d6a7a005-d73b-4860-b399-71a4caf8e15e">
      <Text>I don't— my files don’t indicate any children under parental supervision here.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="727732bd-41b1-4377-8f88-1c8e18d2eda8">
      <Text>He looks at Jamie. At the burrs on his hoodie. At the bodega Nikes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="066bd30a-8dae-4dcd-9ca2-799d09249c2d">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="c8dfc4d7-f242-44bb-be7d-e8db61041c58">
      <Text>(recalibrating)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="115ea6df-9dc7-4833-9092-3303e3b5facb">
      <Text>I'll need disclosure from all parties in residence. Including both the— younger members of the household. Their devices fall under the supervision umbrella.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="076eaceb-b808-41c2-b15b-898b8f101bd2">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dd9b5c9f-abc1-4d9e-9140-4a61a8dad6bc">
      <Text>They don't.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5826e35b-d8b5-4693-bd1e-1106016927ad">
      <Text>Dennis looks at him.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7c7ea499-355c-4737-8d4a-241d3a6df3d8">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="89d3f286-a544-4454-9128-2f4054f7782c">
      <Text>Jamie McCort is a minor currently under the kinship guardianship of his adult sister, Jasmine McCort. He is not under Mr. McCort's supervision. His devices are not subject to the release conditions.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="68c39ea0-87b5-4178-8be1-aa391f38d1c0">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7ac3b6b3-3cb7-472e-b412-5cc8dd40f569">
      <Text>Mr. Reid—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0f4ff268-e461-44f1-b1b6-e606d0202935">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="41973081-dc05-4873-871a-07adfb81bf49">
      <Text>Additionally, Jamie's phone was seized as part of the warrant executed at the family residence.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="929edd67-84a7-4264-83e5-50cc29f0738c">
      <Text>Dennis slowly makes a note of this.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e7453caa-f7dc-40e0-8590-52968b1e3f81">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="646eed0d-c4ec-4593-847b-c961aa09a1a9">
      <Text>And the young woman.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5e2b90fd-7d74-4ff6-8642-0f75b1471f68">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d376e3fa-bb89-4c0b-ae25-de4212dd880d">
      <Text>Jasmine McCort is the property owner of record. She is not under supervision. Her phone is her own property, entirely unconnected to the case or the release conditions, and is not subject to your authority.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cfe99245-43f4-4724-9482-9eb173e72515">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="ef1d19fa-26f6-45c7-a0c8-0168673560e1">
      <Text>(still condescending)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ef2ee534-21ef-491a-910c-95171423297b">
      <Text>I understand your position, counselor. However, any device in regular use by a supervised individual—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d9dbe2b8-fb52-47cb-868b-5718635bc2bb">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="516a657b-9774-4456-9b9b-10af788b3a4a">
      <Text>She's not supervised. I just said that.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="63c2d4bf-5930-4a88-8112-124987bc5cc3">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d6d06152-d588-4c04-9b2e-11f7c45c20d7">
      <Text>—or regularly present in the supervised residence—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c19afe00-f505-4148-92cb-d6a3e0e52fbe">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="90c211c9-f1b8-4fc3-94b6-5a77d65b6d5d">
      <Text>That's not in the statute.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4a107db5-3d80-4878-8eb5-23cb3c193896">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e8d10f64-7bc7-45f4-8d28-d3b5f0f64214">
      <Text>(that smile, holding)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eef1855d-a60e-4de4-8179-a03144ad2534">
      <Text>I appreciate your familiarity with the statute, Mr. Reid. I've been applying it for twenty years.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="01074bde-33b4-4de3-93a6-fa420d5dc79a">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="426aaa5e-c55d-4184-a72e-c24d434ee4db">
      <Text>Then you know it doesn't say that.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1a979998-2fe2-4831-b61e-a5d0d6130027">
      <Text>A beat. The fire pops. Dennis looks at his clipboard. Makes another note. The note is slower than the last one.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aecceeb1-6f85-43a3-9be6-39f26495af1f">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ee0d0054-a637-4ab8-9f85-18267903b8f5">
      <Text>And yourself. You'll have a device.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3498d065-94c2-4a58-8761-3e68eedc7d19">
      <Text>He already knows the answer here, but tries to push anyway.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cb0ba7e3-abc2-416f-a41b-2b3c6a033a58">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4899c89f-1666-467f-9ff3-72623d8d7b02">
      <Text>I'm counsel of record. My devices are protected under attorney-client privilege and is categorically outside the scope of your inspection authority.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="45bba573-2a2e-43dc-9a54-6df167c62f0c">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1d2bea44-dd2b-4915-83dd-99280b0bb3fe">
      <Text>Of course- And what would those be.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ef669f74-a143-435a-b0d1-eae3502fcdda">
      <Text>Hunter pads his pockets, empty. Looks around. Feels for his breast pocket.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2dfe5723-08a4-4264-b892-30e1b47e15da">
      <Text>From across the room, from inside her jacket, Jaz produces Hunter's Samsung. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="8354824f-8e9e-4034-a5b6-4398075bfb1e">
      <Text>Hunter crosses the lobby. Takes it, holds the ancient device up for Dennis. The cracked screen. The hardware. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="5fcb2eb3-f518-4aa7-8b24-62779a5d2a37">
      <Text>Dennis looks at the phone. At Hunter. At the phone.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7987069b-2af6-48b3-8096-d1c6d04785b5">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="45ee7b51-d779-46af-be71-cec6ea031e7e">
      <Text>Good to know.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="45536fdf-3ead-4a69-ab7b-0c828aa39b28">
      <Text>He makes the note. The clipboard comes down. He opens his mouth—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="db712b0c-da56-4cf3-a043-be92bd6db2c8">
      <Text>And stops.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="00b132ed-8a19-440a-9d11-5daf5ba2b427">
      <Text>Something in the room has changed. Not a sound. An atmosphere. The quality of light from the eastern corridor has shifted, somehow, or the air has, or the fire has found a new draught—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7bdb4540-75f7-4898-a7a5-42046b6dc368">
      <Text>Everyone turns.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1debfe84-af14-40ba-9ce2-25d8de2f2303">
      <Text>JANET McCORT is standing at the corridor entrance.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f96146d5-2460-4e4f-b7a6-2ca8ea1ccac5">
      <Text>She is not in the Lululemon.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f68758f6-3555-4e49-9146-268ce9934787">
      <Text>She is in white. At first glance— a gown. A thing that would not be out of place at a charity dinner on the Upper East Side. Draped, structured, falling from the shoulder with the easy authority of something that cost a great deal of money.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9bf75af5-40d2-4d07-afad-b6db5ab4a603">
      <Text>At second glance— it is a bedsheet. One of the sealed plastic-wrapped hotel sheets from Jaz's linen cart, folded and wrapped with the skill and grace.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f3e42f69-0be0-4aa2-a6a8-54177fe7cc1e">
      <Text>Her hair is up. Fresh somehow. She is barefoot, which would undercut anyone else. On Janet, it reads as a choice.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a1a12b69-6ab5-4781-a90d-f072ef41b90d">
      <Text>Jaz stares at her mother.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="68bc3b87-625f-47dd-b5a4-a99af0134d15">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="6563fda4-cb31-4fef-9e0a-d67dc77704ba">
      <Text>(involuntary, quiet)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="300584c7-adbf-44f4-a927-7c8dab52ff81">
      <Text>wow-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="eb0c56df-bfa1-49b8-b767-0b3af27aaf75">
      <Text>Kevin is a quiet raging paradox. His anger of betrayal flaring at the mere sight of her- fights with his swelling pride of the sight of his wife having just walked in wearing a bedsheet like she owns the Waldorf.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f91c2fa8-6451-450c-9f1a-eaa5308a2267">
      <Text>Janet takes in the room. Kevin. Hunter. The kids. And Dennis Pruitt.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5a55db8e-9a6b-4ee7-80db-af37fb3248d3">
      <Text>She sees in Dennis’ eyes that particular look she is too familiar with when men look at her.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9e9a6af3-818f-4f16-96f2-1c5bd713ad43">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="0e0747c6-f1a5-485b-aab2-db02bbfcaa63">
      <Text>(completely even)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e445c739-38a2-4f65-8a41-2b7ad774f078">
      <Text>Good morning.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="61820214-b5a9-48d8-acbb-4de783867c23">
      <Text>She crosses the lobby toward the fireplace. Her feet on the stone. The sheet moving with her. She crouches at the hearth and holds her hands out to the heat, back to the room, as if she has not a care in the world.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="110cae70-b1d3-422e-9f2c-642ac1566436">
      <Text>Hunter glances at Kevin. Kevin is looking at his wife's back.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0c877bc4-58de-4bee-9c07-0acbb13f1d27">
      <Text>Dennis snaps to, recalibrating for the new audience.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a52ad89c-fcbd-484a-bd49-6205a2a61eb1">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e02740d6-ff7c-420f-bf18-2000dca596d0">
      <Text>Mrs. McCort. Dennis Pruitt, Sussex County Pretrial Services.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1c2ccfe1-6f15-4842-ba92-c29972dae7a4">
      <Text>He crosses toward her. His hand extended.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="64880125-c745-40ab-8adb-91aff029c2f5">
      <Text>Janet turns from the fire. Looks at the hand, then looks at his face. She stands, takes his hand with practiced ease. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="54cef66a-62e4-4e38-846b-a17e806930c3">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="f51deb15-0441-4947-aed6-6e43c9166014">
      <Text>(completely warm)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="860180bf-ee3a-44f6-8a34-13b45913f2a9">
      <Text>Mr. Pruitt. It's good to meet you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ac150018-7b5d-4b36-8724-ebd4ba019e88">
      <Text>Dennis holds the handshake a beat too long.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="202be4fc-98c1-4cfa-9c08-6673e52a5d55">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="23f73786-e6d1-4ccb-97b6-809966f290d5">
      <Text>I was just getting acquainted with your— family. Going over the framework. We were just about to discuss device registration—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="95d9f600-4edf-4f0f-8fc0-defa5deea81b">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="5f0c4675-fc85-49be-85b3-f53794c6b1d7">
      <Text>(from across the lobby)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f70a4446-054a-4bb4-b288-3803e8858871">
      <Text>We'll address the device question through proper channels at the appropriate time. Thank you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4fd66200-98a0-43ca-9515-f5a56beda783">
      <Text>Dennis looks at Hunter, that condescending smile returning just for him. Then-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9d1063b1-df74-48fa-8a06-558d72cc75f8">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="1e8d1bd1-239f-4493-8640-3de1bfe62493">
      <Text>(to Kevin, not Hunter)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="44c6162d-3b0b-44d3-8bf0-c7ff6bed9840">
      <Text>You have a— very engaged attorney, Mr. McCort.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="96d1460b-12c9-4eed-897f-72e9c2d77248">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="f9670e0d-992b-485c-8aa0-d134e6579b6d">
      <Text>(looking at his wife)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2cbaa619-df7d-4fec-aaf9-4e3bf9196a35">
      <Text>Yes. I do.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c022b64a-f1a5-4cd4-a616-b6b60dc010f5">
      <Text>The fire breathes. The copper wall catches it as Dennis looks at his clipboard, then back at Janet. Back at his clipboard.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4b7d6bf1-7d7a-40ad-964e-d678ef7c8d1c">
      <Text>Taps it once with the pen.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5c085cb0-7607-4ced-beda-1328fcb28b2c">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e99918c2-1a7b-4ed9-973a-f74397bdf678">
      <Text>(angling toward Janet)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="77d28359-7761-4cd4-9105-d9580cbc8955">
      <Text>Now. Mrs. McCort. I want to make sure we address your situation specifically, because your conditions of release are— distinct from your husband's. You have your own compliance requirements. And I notice from my file that you don't currently have legal representation in place.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9a63a347-004b-4708-9d5e-6645d58a0806">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d8660d38-edea-40d4-8656-1ddfeca2e514">
      <Text>That's being addressed—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e0b627e7-b1a6-4ec6-a911-b3583070655c">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="8de37a1c-33fc-42bc-a8f9-70271eceb688">
      <Text>(not looking at Hunter)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="28fe54d0-0e4f-451c-a720-9a1a2cafa7da">
      <Text>Mr. Reid. You represent Mr. McCort.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a1ceb9c0-ba95-4fad-bbac-0010ac9021de">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="be7f70fd-e02e-4413-8f53-a8bc8f5a6285">
      <Text>I'm aware of who I represent.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="21311c64-a110-4bad-8b62-2874fe427e75">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5296d394-b746-4e57-8d76-0c183b1efe8f">
      <Text>Then you'll appreciate that Mrs. McCort's pretrial conditions, her representation status, her schedule, her— situation does not involve you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d9924989-8031-433f-bc12-9df3f18830d3">
      <Text>A beat.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="856623f7-21bf-47ad-b892-ec0804dec978">
      <Text>Kevin opens his mouth to object.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c972e979-378c-4c4c-8d2f-ba8d77d9c6e9">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="9b5b7188-19a4-4ad5-b8cc-a36c0f35df78">
      <Text>(to Kevin)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="571c4969-5c6b-40da-b015-0d68edb6e6cf">
      <Text>And I know you want to be helpful, Mr. McCort. But any discussion of Mrs. McCort's legal situation, her conditions, her representation, her schedule as it relates to these proceedings— any of that, between the two of you, is a violation of the co-defendant contact order. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="c4a09ea0-7f81-484b-a198-61830e76e7a8">
      <Text>He looks at Hunter.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="146b76c5-3dca-4165-9711-092ec0b5bc36">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="72d723dd-a69f-46aa-b586-ef26e8382920">
      <Text>Isn't that right, counselor.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="27ae03ea-f7e3-4856-99ad-716fd0e10611">
      <Text>Hunter looks at Kevin. The pause is very short and costs a great deal.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2e052b5e-a3af-4086-b3f3-8c7a760fc9b0">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="6ca6c95d-65fd-405c-9301-a0fbd32d96a1">
      <Text>(flat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0e464d56-bdc4-4ebe-a7d4-0f4b3ea90535">
      <Text>That's correct.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3928f792-379c-4aa6-a7f9-9887366f3c94">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d78fb8a5-2888-46fd-a939-534422a370d0">
      <Text>(back to Kevin, unhurried)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7c061e31-d731-40bd-bc85-d77096d75204">
      <Text>So here's where we are. Your wife is unrepresented. She's under my supervision specifically. And until she has her own counsel in place, my professional obligation— is to work with her directly. One on one. To make sure her needs- are fully satisfied, and right now- I’m the only one that is allowed to- Satisfy her needs.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ac240f50-70c3-437a-b14c-08c11a620b4a">
      <Text>He lets the innuendo sit in the room for exactly the right amount of time. Let’s this burn into Kevin.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5830f5ff-2cca-4837-9c27-088aa6596cd5">
      <Text>He doesn't look away from Kevin when he says it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e726d6a6-c156-4d4d-a760-0be2f2ae823d">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2969a507-9898-47d2-ab80-b18c90c0f7a3">
      <Text>Because here's the thing, Mr. McCort. This co-habitation provision- in the marital bed— that's not automatic. That's a determination I make. Whether there's any indication that the presence of a co-defendant is—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ed77a86a-0984-4d9e-a937-97505605e6cb">
      <Text>He tilts his head. Fractionally.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c00b7ada-b4e1-4496-9ad2-889607bc7cd7">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8823a0f7-34b0-4b96-8346-010da4515f9a">
      <Text>—interfering with Mrs. McCort's ability to comply to me- and only to me.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="016c6232-e0fc-442c-bd6a-af9cbb61323c">
      <Text>Kevin is very still.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="032cb5aa-04bf-489f-b9c8-d24ce2b13175">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1d55b70e-b3c1-41f7-bb7c-9d28ffcf4bd3">
      <Text>I'd hate for anything to complicate my opinion on this.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="a53249a2-f059-430b-a457-586034a5f3d8">
      <Text>(a beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="94ca20fd-68c9-44bd-881e-d3fe6951fcf2">
      <Text>Wouldn't you?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="05b25aff-08fc-464b-9ffd-81222f5b806e">
      <Text>Kevin looks at Hunter.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d36949bb-9892-466a-82d8-9944c112fc1e">
      <Text>Hunter's face says: SHUT THE FUCK UP.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b6fc884f-5b38-4807-90f3-ab58317b593b">
      <Text>Kevin's face says twelve things simultaneously, none of which he is permitted to say.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8ad4c8dd-9968-4533-9299-4d6e9d9ea1f7">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="a36f0268-cf1c-44b8-9e67-81225812eed3">
      <Text>(to Hunter, condescension returning)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c4073d2f-c97c-4acf-9824-10896690da56">
      <Text>And I want to be clear— If I find that counsel is inserting himself into </Text>
      <Text Style="Italic">MY</Text>
      <Text> supervisory relationship with Mrs. McCort— coaching her, communicating through her, using her as a— conduit for strategy that properly belongs to Mr. McCort's defense— that's obstruction of my supervisory function. That's a filing. And filings have consequences that go well beyond the device question.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c93508a2-8019-4c35-8b66-bdf108119e3b">
      <Text>He says it as a absolutely clear threat.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d64481cf-dc3a-4437-bfbb-495fbf5f994e">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="c8d5d32c-cf64-4f27-884a-b1e9f0c5504b">
      <Text>(even, careful)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="df85f6c2-c3cc-4745-958f-c7ae1ff75bd4">
      <Text>My communication with Mrs. McCort will remain within appropriate professional boundaries.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cf7b6e14-da66-4094-a9a3-b0170c0ad267">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d0dfdc47-5ad9-419e-8c99-7b007168e06a">
      <Text>I have no doubt of that.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d7d18546-5707-43af-b6b0-e4bf0b54fb2c">
      <Text>He turns back to Janet, and that smile becomes something else— warmer, private, he got up before the sun for her.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c9626db8-a6f6-4bea-9ce3-b7ce2552d60d">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f1cb8d76-6caf-4676-9441-0ac777af5ce2">
      <Text>Mrs. McCort. I want to make sure we have a few minutes— just us— to go over your specific personal conditions. Make sure you're comfortable.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="104b8f29-beef-48e5-8b05-f32efbfafa99">
      <Text>Kevin's jaw works harder to keep his mouth shut.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cbb1efb3-4145-4388-94fd-79263a0c4930">
      <Text>Janet rises from the hearth. The sheet moves with her.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="134aff50-95fd-424e-a4c6-fe059e5a3c9e">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="605324dc-b06f-4386-abeb-9d0781de77e5">
      <Text>Of course.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="433cd434-df15-453d-8991-d2e7449a628a">
      <Text>She crosses to him. Her hand finds the crux of his elbow— light, practiced, the skillset of leading while appearing to follow. Dennis instantly stands one inch taller at the touch.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bb28cfa2-3a2f-4330-bdfe-1780dc3ac6f4">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4996bbe8-30a3-4f41-990c-cde096a2d089">
      <Text>Show me where you'd suggest we talk.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="87a584d7-efb6-4712-b032-691df4f64d6b">
      <Text>She’s already moving toward the Sidewalk Cafe.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8fee1c96-69f5-4572-a21b-22a4a9d6c5ec">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="f2c48964-6c25-43c3-acaa-37e60ea0de03">
      <Text>(to the room, over his shoulder)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="19698632-aba8-4eae-8ece-feb3a39fc102">
      <Text>We shouldn't be more than-</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bd3aae78-bb32-4e11-ab7c-464d874323cd">
      <Text>He checks his watch. A performance of reasonableness.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b9444113-e53f-4867-b1ee-bcc9fd7b1907">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1003088c-704b-4680-8b1d-0f42931f5453">
      <Text>-an hour. Give or take. Depending on what- comes up- or out.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d311cb33-125c-4a3f-8b3b-a55fb5039d91">
      <Text>He doesn't look at Kevin when he says it. He doesn't have to.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9868505b-51b4-4e60-8c63-09e6c390ee1c">
      <Text>They move down the corridor. Janet’s hand in the crux of his arm. The geometric carpet receiving them.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="a99a5cff-9420-4d23-a6ea-b5a44afa599c">
      <SceneProperties Length="6/8" Page="15" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. PENN STATION — 8TH AVENUE ENTRANCE — DAWN</Text>
    </Paragraph>
    <Paragraph Type="Action" id="38e20b88-07e0-4d38-965f-6d8ac8dab3fd">
      <Text>The city before it wants to be awake. Eighth Avenue in the gray-blue wash of first light. Cabs idling. A few joggers. The particular emptiness of midtown before the commute fills it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cefbe0b8-a376-4443-a678-5d04d70d1123">
      <Text>CHUCKLES comes up from the subway. Guitar gig bag over one shoulder, a duffle over the other. Misfits shirt under an unzipped hoodie. He hasn't slept. The jaw is doing its thing.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a8ce3f6a-99b8-4bcc-b304-36eef97267dd">
      <Text>He stops at the curb. Pulls out his phone.</Text>
    </Paragraph>
    <Paragraph Type="Shot" id="9b471b5e-2161-405a-bc4e-9d56ba785dac">
      <Text>INSERT — CHUCKLES' PHONE</Text>
    </Paragraph>
    <Paragraph Type="Action" id="58106e4a-84c6-4bb5-89e3-49327081c5dc">
      <Text>We see Jaz’s text: I found it. Meet me here as soon as you can.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="58106e4a-84c6-4bb5-89e3-49327081c5dc">
      <Text>He flips to Google Maps. The blue route line running northwest out of Manhattan, across the George Washington Bridge, through the body of New Jersey. The destination pin sits in a green void northwest of a town called VERNON. The estimated travel time: 2 hr 47 min. The pin label reads: PLAYBOY RESORT, ROUTE 515, VERNON TOWNSHIP, NJ.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dbd49ab9-3d32-40bd-84de-fba1f0f6ce5b">
      <Text>He pinches out. The green swallows the route. Nothing around it. Nothing near it. The pin alone in all that space.</Text>
    </Paragraph>
    <Paragraph Type="Shot" id="f26d36ff-3c90-4832-9b2e-04489e19320d">
      <Text>BACK TO SCENE</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2f414028-58bd-4e43-aefb-0febb3f5d0de">
      <Text>Chuckles looks at it a beat longer than someone checking directions would. He pockets the phone. Crosses toward the NJ Transit terminal entrance. The duffel shifts on his shoulder.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="f1a0a97d-027d-4477-ac0b-fdcac048a852">
      <SceneProperties Length="2/8" Page="16" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. NJ TRANSIT BUS — MOMENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="55c7028a-64e7-4133-817e-a3e8c7c77d6e">
      <Text>Chuckles in a window seat near the back. The bus mostly empty— a few hospital shift workers, a guy asleep across two seats. The overhead lights humming that particular transit blue.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3317dd66-8f1f-49b7-9ce5-86480293c4dd">
      <Text>The bus pulls out. Manhattan sliding past the window in the early light.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="796a5aee-324c-44cb-8846-410a1478772e">
      <Text>He watches it go.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="a4d09cde-e11b-4b68-b740-805b8eb01a1f">
      <SceneProperties Length="4 5/8" Page="16" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DENNIS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JANET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT - SIDEWALK CAFÉ - MOMENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action" id="53b18bd6-18d7-4421-b3b7-2f3b71b56209">
      <Text>The café in morning light. Early sun filters through dirty glass ceiling panels, diffuse and gold. The tree in the center reaching toward it. The wrought iron lamps throwing long shadows across empty tables.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1cd1e9fe-d880-4973-a330-111106414f15">
      <Text>Janet at a two-top near the tree. The sheet arranged, hands in her lap.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="98ad4fc3-db87-475c-bc6f-15ff22709ef8">
      <Text>Dennis sits across from her. Clipboard on the table, hands folded on top of it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="08c428ec-a1ce-44d7-aeb0-6fe6b661e1c4">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="518ace1a-d10c-4e2a-b3b9-6e756b435978">
      <Text>So. Janet.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c93d36e9-031f-4284-9dcd-2cab59858067">
      <Text>He looks at her the way he looked at her mugshot last night, except now there is no monitor glass between them.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="95a0c587-de51-45d7-9169-d517da045c31">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="74b09235-9dc0-43ab-a93f-75e314f8f235">
      <Text>I'm going to speak plainly. I find it works better. more intimate for just the two of us.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b126e7fc-c486-4964-960c-ba2926068e1b">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="faca4f81-d2f7-4f21-8976-ec6af833e14e">
      <Text>I appreciate that.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="df04f407-fbf8-4059-a3f9-fb5c4041cf24">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8b6f6a91-20ba-4e67-930d-aff25097caf7">
      <Text>I've been doing this work twenty years. And I can read a situation. See whats real, underneath all the— paperwork.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="727ce0f0-d0eb-449d-85a5-1ffd7c4d6caa">
      <Text>He leans forward. His forearms on the table.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bd9a8f93-d6b3-4727-9c60-bd536df063ed">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="166b031b-043f-428a-826e-5fd40eedc71a">
      <Text>When I look at you— and I want you to know I have looked— what I see is extraordinary. I think you’ve been wasted- Tied down by a man who took what he needed from you and called it a marriage. Kids who needed everything you had.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6c261d2b-a083-4a30-b703-5b454fe2d244">
      <Text>He shakes his head. Aggrieved on her behalf.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="430ea069-c8d8-4321-8a5f-0c8ab40b0846">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ab913884-350a-4cb4-b1bb-e5f321204357">
      <Text>You deserve someone who actually— appreciates what's in front of him.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="06550145-1b05-42b1-87ab-f4dd27e30881">
      <Text>He holds. Trying to gaze deep into her eyes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c84d09ca-9201-42ba-97ee-63a4541a1d0e">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="10941d80-ef75-4322-895c-c26a50f4f648">
      <Text>(softly)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="598d70d5-0067-48fe-b27a-0b54739139d8">
      <Text>That's— very sweet of you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7df53564-af72-4e11-b3f5-95a978c87bef">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a1810f5f-39c3-400c-8173-1e8dc1650be9">
      <Text>I'm a sweet man.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="619e2ee9-91c5-4c65-9538-51f9150090e1">
      <Text>He sits back. The posture shift of a man moving from sympathy to the same thing masked as business.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="34ea6ec6-1c3c-4708-9403-54a08aede1dd">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="11c6bf0a-1840-4ebe-9312-79846ec20d38">
      <Text>Now. Your situation. You're here, you're unrepresented, you've got nobody in your corner. But, that changes today. I am taking a </Text>
      <Text Style="Italic">personal </Text>
      <Text>interest in making sure you have everything you need.  </Text>
      <Text Style="Italic">Personal</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="54f7451d-68bd-47a6-b3c2-520adf91a09b">
      <Text>He wants her to hear the word the way he means it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a52ecded-3210-4743-a057-ceb7b98e529f">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5c3ca037-0b9d-4e81-92a3-81a01396cffb">
      <Text>The travel provision— I can open that up for you. Significantly. You want to go into town, get some air, get some real clothes—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ebc17876-a896-4543-be91-c5ce6e6bab71">
      <Text>His eyes move down. The sheet. lingering on her cleavage. She does not make a move to cover.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f2d51aac-9a51-49ae-ab36-db32212e5d90">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2ef8528f-f802-4a31-96fc-2bc5ca5b0a2e">
      <Text>—get yourself feeling like yourself again. I can make that happen. My discretion. Which means if you and I have an understanding—</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="a701cebf-198f-4f82-9f31-c68ac8debbbe">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ebcf1ae4-15ce-4746-8ab6-dabd6ece4746">
      <Text>—you're not stuck in anything.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ddfe8294-42e9-4adb-a900-3c722d55ae33">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="54caba38-9800-4847-b423-918c6706ef33">
      <Text>An understanding.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="78e78cb8-2140-49b5-b565-dffdf9986694">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e21ce968-22a4-48dc-86b8-e788aa3b7920">
      <Text>A working relationship. You're— available to me. When I need to reach you. Day or night, my job doesn't have hours and neither does yours right now.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="adb67898-d733-49b1-850c-5f7abdb24288">
      <Text>He subconsciously licks his lips.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d5f96758-94f6-459d-95a8-782639961f44">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e22d9e25-cb4e-4a7e-9264-6161cb7b5ead">
      <Text>I need to know that you're— open. With me. Completely open. No walls, no filters, nothing between you and me that I haven't approved. This relationship is private. And what happens between a supervisor and his—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ce467dd7-b529-47fd-aecb-0662d9141ecb">
      <Text>He pauses. Selects.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f64476b5-766f-473f-806d-e693e4941e66">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="11f03de3-accf-4288-9868-18bc36f2e574">
      <Text>—his person. That stays between them.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dc7a2f6a-43b9-43c8-bd36-084a7e73236b">
      <Text>Janet holds his gaze. She remains unreadable.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="180e6350-49ea-41e5-87df-bbfb74d2e342">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="75864c3a-9e99-4404-87dc-68e17490f4d3">
      <Text>There's a lawyer in Vernon. I'll be honest, I don't know her well. She's a— solo shop. Probably does mostly divorces, that type. She's—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7580d969-1ad5-4f7e-a7cf-47ef56b522dc">
      <Text>He shrugs. A small dismissal.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7d43eed0-edc9-4b4b-af37-86bc6556cdab">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9469725f-2ab5-4641-819f-5a8e5b472b48">
      <Text>Mexican- or something- Spanish. She'll do for what we need.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="25966db5-0b3b-4eca-ba94-a26c8e4a30c1">
      <Text>He leans in again. His voice drops.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ba80f2c6-92d4-4bb6-b0dd-848215f4c3e7">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="32441a5b-b6b4-4ec7-89b5-4e8c7b4a51b1">
      <Text>But here's what I want you to understand, Janet. That lawyer— whoever she is— she's going to tell you things. About your rights, about your options, about what you can and can't do. But she doesn't know your situation the way I do.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="38a8c166-951c-4f35-8fe3-f3a026959ec4">
      <Text>He touches the ankle monitor log on his clipboard. Taps it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6299f8b9-9003-43bb-8429-6e35e08a44a6">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="56b3e787-96dd-4959-8af7-dbf97b283560">
      <Text>I know exactly where you are every minute of every day. I know when you leave, I know where you go and how long you're there. That's not a threat. That's just— the nature of our relationship.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="020cd33e-5c1e-49ad-96b7-4679a512f457">
      <Text>He smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2a0f94d6-8eae-463d-bcb0-47b92a3c299d">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5d2e1904-0975-4aa7-821e-00f4766bff2c">
      <Text>What I'm offering to be for you is someone who uses that knowledge to take care of you. Rather than— the alternative.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="58f75bbc-3787-4e67-993d-7dc4040b95d5">
      <Text>He lets his gaze linger longer.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5754cd6c-2f71-4d92-8fcd-160ba806a046">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="820595dd-1c69-481b-999a-440b7e6e511a">
      <Text>Now. The phone. You need one, today if possible, because I need a direct line to you at all times. My number is the first number that goes in it, I’m the first one you call.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="49efdeba-d905-4a03-99cf-88e78d624a14">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f8478d4f-854d-419c-b707-e30b72a2fa86">
      <Text>No encryption. No disappearing messages. No apps that put anything between you and me. I want— complete exposer. To me.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="26b12ee9-777c-4d0f-a04a-a1ba7f8e0fc5">
      <Text>He holds her gaze, trying to see behind her mask. Waiting to see if she is freaked out at all. Then-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f39df97a-7146-4dda-85ee-d0ef90e7e424">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="3dfeb750-4238-44a1-a121-1a898592e26a">
      <Text>(pushing harder)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c50c10bb-75cb-409d-b238-4714515ed5d5">
      <Text>Think of it as— intimacy. You let me in deep- all the way in, I take care of you. That's the deal.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e78a785f-98bd-40d9-ad34-2a3808ea47f6">
      <Text>(waiting for her to freak out, then pushing harder)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c13fbd9b-88dc-4bde-8ba1-735e83c635a2">
      <Text>You do that— you prove to me that I can trust you completely— and I will make this process so much easier than you can imagine. We’ll be together in this. Against your husband's lawyers, against the DA, against anyone who doesn't see you the way I see you.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="6f626dac-5be3-4029-b850-c605631baa07">
      <Text>(very quiet)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8b28b4ea-840c-4e0c-84bf-5cb0801cb015">
      <Text>And I see you, Janet. I know what you need.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="30378993-d783-4265-a5b2-247cef3bee98">
      <Text>He holds it. The full weight of it. His eyes on her face.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8057fd13-5868-474a-8cfa-4652fc227390">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="40b8744d-b5f8-4331-ae26-39661f8b741d">
      <Text>The question I need you to answer for me right now— just for me, just between us— </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="faf9d676-5ba6-436c-b057-1774f9d4667a">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="40b8744d-b5f8-4331-ae26-39661f8b741d">
      <Text>Whether you're willing to give this— give us— everything you've got.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d0ef89c9-3ba2-426c-9282-7bca399b13cf">
      <Text>The café holds the silence.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6f273e3b-bd7c-4dbd-96db-86a9c03ad922">
      <Text>The tree reaches toward the dirty glass.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="aaaf8400-298d-4bc5-b5fb-0cfd74e039ef">
      <Text>He thinks he has her. She is going to let him think that for exactly as long as it takes. He has no idea how fucked he is.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f4c7eb71-380e-4132-bc45-6dd14f98e6eb">
      <Text>Janet looks at Dennis Pruitt. She is warm. She is present. She knows she has full control of him now, she’s known how to bend every man that looked at her with this kind of crushing insecurity that radiates from them.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="97791eac-62f0-4a4d-9a29-0c5061170270">
      <Text>She reaches across the table. Places her hand on his. Light. A gesture that costs her absolutely nothing and lands on him like a death sentence.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dda2a124-5e75-4df6-b04a-6fb9230acf37">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="168e3af9-5514-4164-878b-42ced1206882">
      <Text>(barely above a whisper)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="49422ddd-b562-4fbf-92c8-fc67919b0926">
      <Text>Dennis, I’m so lost, thank you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="49a1f76f-25e3-45fb-866e-ebe5d4aa7cca">
      <Text>She lets him hold that for three full seconds while it hooks in to his brain stem. She see it take hold and root into his ego.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7f5181f0-0b46-4b32-a626-41565991d9c6">
      <Text>Dennis looks at her hand on his. He looks at her face.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2fc5308c-65c3-4d70-815c-3cd2bc4defd3">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6c14259d-0a37-45f1-bbfe-a081d2f2756f">
      <Text>Now. Tell me about this lawyer.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0fb6e255-0829-467f-a572-9112850e2ca2">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d2c4a59f-a80c-4e35-8c3e-7710b9aaa507">
      <Text>(clearing his throat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="924c623d-8b2b-4428-8889-1dc9db9b2594">
      <Text>Her name's Vásquez-something. I'll drive you there today.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f06a0ceb-04f6-47dc-a7a9-98d6eaf55891">
      <Text>He writes a note. His pen moving. The warmth of a man who has just gotten what he came for.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="e8779334-cad0-414e-9fbb-4a69a0afbf85">
      <SceneProperties Length="1 7/8" Page="20" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="HUNTER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JAZ">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEVIN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT - LOBBY - DAWN - CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="15fbdb1e-ea57-45ca-877d-e42002445573">
      <Text>Kevin is behind the reception desk, not moving. His hands are flat on the counter. The ankle monitor light reflection on the slate floor.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="be3fba8d-30fa-4f4f-a9a3-552355127579">
      <Text>Jaz is watching the corridor.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9b7989c4-613f-4d46-a211-70e48fdee117">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="b1517657-4d8d-44b0-9684-9a82c950ba42">
      <Text>(quiet)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8aa64c3b-9e78-43c6-b70c-8eb42bcfe8bc">
      <Text>She's fine.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="650c5434-eb14-4438-b1d6-6b029e9a049d">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4bfd097b-4d69-4e9d-91d8-9f71e3554820">
      <Text>I know she's fine.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cec05e5f-0538-4450-bef8-cfbdf31bce46">
      <Text>She looks at her father, pausing to take stock of the maelstrom behind his eyes that she’s never seen before.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3cae5cd5-6e1d-4847-91cf-6bc9f83f64d0">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="81a5a8dc-f1f4-43c3-ae2a-b45a063f7b95">
      <Text>She's better than he is at this game.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="57bd890e-2f0e-4eaf-97d1-fd517af28edd">
      <Text>Kevin doesn't answer.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="374ee83e-f07d-4f2b-b4e1-9bb3f6b1f5cf">
      <Text>Across the lobby Hunter has the Samsung out. He is standing very still beside the armchair. The screen is lit.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1009a75e-e33c-44fe-9388-b95c4f5a8b81">
      <Text>He is reading the thread from Janet’s backlog of messages that synced. Running his thumb up through it slowly, the timestamps going back, back, back. The names. The messages. The photographs.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ff756c34-14fe-4b2c-966d-df4fe42dc9ed">
      <Text>His face is doing nothing other than blanching pale then turning a nauseated green, then back to dead white.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2d9216b1-a01b-4e28-a754-34a04a79aed6">
      <Text>He lowers the phone.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9cd25d84-837a-446f-990f-97295c17e664">
      <Text>He looks at the corridor at where Janet and Dennis disappeared.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b123c648-2a0f-4a0b-a1b6-dddf235a0256">
      <Text>He looks at the phone. Looks a Kevin. Back at the corridor.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9494f59d-59bb-4110-8515-0d3394eb1825">
      <Text>Jamie watches him with curiosity of his that is always trying to fill in the gaps.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e6dfed05-f472-49c4-94d7-ca3662c12ba3">
      <Text>Hunter has seen too much, puts the phone in his jacket pocket. Picks up the legal pad. Puts it back down.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e4f58765-3ae8-4480-aba3-11ab023c6f1d">
      <Text>His growing agitation becoming impossible to ignore from behind the reception desk.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f57ab653-87b2-46aa-93d8-a6876799942a">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7d1bbae2-ba89-4adb-b8a3-c8cb92e654d8">
      <Text>(low)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7aa5a28b-0949-4fa5-828c-99ac03348352">
      <Text>How bad.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e2c8c28d-9c75-4a70-b9f3-6b634d6aed6f">
      <Text>Hunter looks at him.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a1c3ecf0-2aee-4f6b-82e7-2cb9b2b2c76f">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e43fc9b3-b4a8-4beb-a17c-35bd54eb7dce">
      <Text>(carefully)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f6a3deee-1c14-4763-87ad-d0da834e648f">
      <Text>It's a- a situation.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ff3266c6-0d9a-481c-bfb3-d465771657a8">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bee8a44d-1c6d-4df6-9f61-5366ab5f86d8">
      <Text>How much of a situation.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f8fe3d7e-32d6-490c-b5fb-1f9d226ea699">
      <Text>Hunter picks up the legal pad again. Holds it. Sets it back down.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4d077218-3699-4a60-845e-642693a3a449">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="513cf2ed-6576-4b4c-864b-620296480eff">
      <Text>The kind we're going to need to talk about. Privately. Soon. Like before we talk about anything else.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2b9c154d-0191-4b5e-ba90-32b483376ee3">
      <Text>Kevin looks at the corridor. Jaz following his gaze.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="336e165b-7fdb-4f5a-8b13-756ae38b61d7">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="98e1aae7-1bad-4b89-917f-4a4d9248dcb5">
      <Text>You know she owns that man already, right? He lost that fight the moment he looked at her that way.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8976ee3b-27a5-46f5-9480-407720077d5b">
      <Text>Kevin doesn't answer. Just stares at his hands.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ec65863c-5c20-4f41-bf25-b5376e4a86d5">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cfdd8801-5c71-47e7-86be-301e646def38">
      <Text>She's been owning men like that her whole life.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f32589d9-8795-4ed6-8b46-b11546a66e95">
      <Text>A long beat. Kevin finally looks at his daughter. Something moves in his face-</Text>
      <Text Font="Sans Devanagari Final Draft"> </Text>
    </Paragraph>
    <Paragraph Type="Character" id="1bc72538-cc70-4c8c-a5c9-1e9dbdaa06a6">
      <Text>Kevin</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4546eaf8-f002-42d3-ba1d-434c1fbbadfd">
      <Text>How long have you- known?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="30e1ffbe-1304-4c4c-8bbc-7c3552eeb3d3">
      <Text>He looks back at the corridor.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ac722523-049c-4b96-84ac-a39e17053d8a">
      <Text>Jaz</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4aab3176-b122-47fe-b6dc-0da4c62ab4a3">
      <Text>I’ve never not known. If you honestly didn’t it’s just because you never bothered to look.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="770ddbd1-7a81-4233-b196-a872fe453e41">
      <SceneProperties Length="4/8" Page="22" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. NEWTON - SUSSEX COUNTY RECORDER'S OFFICE - MORNING</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f3005aa1-6648-4fc5-be0c-954d5c4d5813">
      <Text>The Newton courthouse square. The war memorial. Buildings that have been here since before anyone currently alive remembers.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c001112f-cd55-4bbd-860c-31715b43f53a">
      <Text>A HUMMER EV in matte black takes up two and a half spaces in the municipal lot across the street.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="efdf66f2-d989-4d76-8d1a-cc969535954b">
      <Text>The door opens. TANNER unfolds out of it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="215a72c7-0727-4213-b7e6-8ef6bdfbe761">
      <Text>Fresh suit. Charcoal, fitted, the suit of a man who wants the world to know he has resources. His hair is perfect. His right hand is wrapped still in that same hospital gauze. It’s not even close to white anymore. It’s gone dark red to the wrist, soaked all the way through sometime yesterday. Brown at the edges. A smell that is beginning to taint the morning air.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="69e5af00-d70e-4500-b7d6-94066a0aac68">
      <Text>Tanner does not care about any of this. He rolls his shoulders, adjusts his jacket with his good hand, and crosses the street toward the Recorder's Office like a man ready for combat.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="4d0ee9af-ed25-4808-ae0f-f84aad99ee48">
      <SceneProperties Length="5" Page="23" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAROL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="OFFICER WASHINGTON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TANNER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. SUSSEX COUNTY RECORDER'S OFFICE - CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5f5e1edc-a2e6-4d66-999b-7658991a2382">
      <Text>The recorder's office has the energy of a government room that has been doing the same thing for sixty years. Drop ceiling. Fluorescent light. A counter running the width of the room. Behind it: filing systems, monitors, the infrastructure of public record.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3cabce58-fe5b-44aa-bf5d-3e29e5fc1785">
      <Text>At the counter: CAROL. Fifties. The cardigan. She has seen everything that could ever decide to walk through this door.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1c4aa37d-efe5-48e4-8bce-8c8359be47bf">
      <Text>She is helping an elderly man with a property transfer when the door opens.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d8f2c859-31ec-422c-9fdd-2591ce186cff">
      <Text>Tanner doesn't wait.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f1005a62-3021-40fe-aec2-467c2d234aa0">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a38248d2-a5a1-4ee2-a115-cc68e0bab85b">
      <Text>I need a deed record. Transfer of title. The Playboy Resort property, Great Gorge. I need to know who it was transferred to and when.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bcfc108d-2019-44ea-98a3-36efe8416016">
      <Text>Carol looks up from the elderly man.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0c53e4cb-0317-4369-b231-39a749bcc41a">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f43d6840-3790-44c0-8fb0-371cd534426f">
      <Text>I'll be right with you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2867393f-7a15-404d-9d0e-85b24c568044">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="406d28a6-bb2d-4250-8941-d8c4d7b1c81c">
      <Text>I need it now.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="81556e43-6510-43f3-8d32-e8838429b627">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b435e804-0c97-4404-97d2-ef8df3087371">
      <Text>(back to the elderly man)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e7fe5b44-d57a-4c38-9b95-7f6e4c1daaf7">
      <Text>So if you just sign here and here—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c9dba019-e4d2-4b91-aba9-068fcdc52d92">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="978abdaa-8120-4319-ae76-132d7980a5d3">
      <Text>I'm sorry, did you hear me? I said I need it now.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="00f62991-f443-4f7e-aa53-eefe773165c7">
      <Text>Carol glares Tanner down, she takes absolutely no shit from men like him. She finishes with the elderly man. Takes her time doing it. Stamps something. Hands it back. Smiles at him genuinely. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="dd1b7d31-0b79-471f-9f62-9ea81b14fa92">
      <Text>Carol turns to Tanner. She looks at him with the comprehensive taxonomy running in the background.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="08f9db63-39c7-44cf-927b-e34b993aec4c">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="42de88b0-d267-471e-b3d2-7151c0fcf02e">
      <Text>Now, how can I help you?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="027a6778-0ac7-4c02-aa3a-3f315bb1fa21">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="04eb35fa-a2b4-48bc-9aa3-4c89f9aafe88">
      <Text>Deed transfer. Playboy Resort, Great Gorge. Recent. I need the grantee name and the filing date.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a6c6d985-aac8-41a0-930d-1ca4efac581c">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e9e981fb-314c-4b9b-a122-b27d76a7968b">
      <Text>Do you have the parcel number?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d52e52b8-83ca-4b2a-867a-6232977d3321">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="da7f2d49-f5ce-4beb-9a86-967d8ba9a723">
      <Text>No. I have the address. The property name. It's an eight-story resort on a mountain in Vernon Township, it's not a needle in a haystack.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="11266cfc-ce97-4b3d-9ccd-665e63807563">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="05e080ed-7d2c-4891-8c6e-c1322edea3c0">
      <Text>I can look it up by address. When was the transfer recorded?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e0821d7f-91df-40cb-a950-97e6435771a0">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="83fa9711-9c70-4ebf-ba75-5b6105b694a9">
      <Text>Yesterday. Maybe. Very recent.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="36d0dfd4-ba81-4e75-b6d4-b8b762778400">
      <Text>Carol looks at him over her glasses.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ef17f9ae-779a-4e04-91c3-95081fbbf734">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e350f9c0-e8a8-43f7-a9f8-5611cb0c6313">
      <Text>Sir, newly recorded documents take at least three weeks to be fully entered into the public record after submission. If this transfer was filed in the last day—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="54b9e3d5-15af-443d-a952-51f27e1e4671">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4a3ca089-9260-400f-b98b-b9941462f01c">
      <Text>Three weeks.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="967904d5-2e88-4174-89ee-9356387b20a1">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f2816c10-8f45-41ef-857d-04e76aae8837">
      <Text>At least, yes. For the digital record to reflect—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7e1e32f1-a0aa-436b-9726-df741ee07978">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="007c957b-24ec-4046-a627-e3f39ee87b71">
      <Text>That's—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8ded6d84-4449-4193-ad60-0478657b64cc">
      <Text>He puts his hand on the counter. The right hand. The gauze lands flat on the laminate surface with a wince and a whimper. His jaw tightens.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3b360a63-6b24-401d-acc6-e83c681563b2">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="91a760e2-3594-43f2-828f-7c3ed19f8155">
      <Text>Okay. I need you to understand something. This is a time-sensitive matter. This is a matter involving significant—</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7b3e2057-ff23-40cb-8510-9357724eef3c">
      <Text>(recalibrates)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="de24c803-c0b8-4de3-b5c7-4fdd0523fa1e">
      <Text>A property that belongs to people I represent— </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d5b3e01b-f50d-43e8-9f65-a8fc779378a5">
      <Text>(Slower and louder)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="de24c803-c0b8-4de3-b5c7-4fdd0523fa1e">
      <Text>it was transferred without authorization, under circumstances that are legally questionable, and I need to know who is currently listed as the grantee so that I can begin the process of—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aabd4701-726a-4e5c-96ac-19bf604e9879">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="86771e2f-0c7f-4212-9d88-1e08f85cbc0f">
      <Text>If you believe there's been an unauthorized transfer you'll want to speak with an attorney and potentially file a—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c5c75a34-d16a-4832-8984-7d2e9c6ce64b">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2017b316-8cf7-403b-bf75-8da8f60900c7">
      <Text>I HAVE an attorney. What I need from YOU is the NAME on the DEED.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3e642055-536b-4040-add5-4dacb7c34b76">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="4e3b9b8e-4741-4226-8955-e747588e4cf3">
      <Text>(completely level)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="17273a41-2b6e-414a-bc50-b8de2d90e6b7">
      <Text>At least 3 weeks to process. That process applies to everyone.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="448f0650-70ea-40e8-8b5d-522cd79c7caf">
      <Text>Tanner looks at her.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="76c7a177-c3c5-44f5-b66d-47882cb64eec">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b5629079-d504-463a-9ab4-9c5431f483a4">
      <Text>I don't think you're understanding me.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8fc62ef3-6834-4b29-b6d2-72e5ca04b15c">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e2e7c47f-cc5b-40df-b049-521ea8addf27">
      <Text>I understand you fine, sir.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="405f5649-01f7-4fa1-b04c-a1f9348823ef">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c8c47bbc-8076-4052-87a0-3afe231282ba">
      <Text>This is urgent.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e8c0116e-e373-4e4b-8d2a-4789fb3f378e">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dc82b41e-7db8-4b13-a5fc-7e9a8f6b9908">
      <Text>I'm sure it is.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="28eb5d32-cb47-4a5e-a0aa-9e9806962a09">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6666f36d-a0c6-4103-a4de-358fc9498c7f">
      <Text>I'm not talking about a routine request. I'm talking about a matter that has significant—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c5c62b85-8ac0-4dad-884e-df80f9d727c7">
      <Text>He puts his hand down on the counter again. Harder. The gauze. The sound is wet this time. His face goes a color it shouldn’t.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="882e0669-2e37-400f-b0fe-8012fb6a0b00">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="39941a82-da43-4404-8a6a-31c21c895623">
      <Text>(looking at the hand)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="09251718-48d2-4401-ae3a-b183cd18b574">
      <Text>Sir, your hand—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bf7f348a-c5f6-48aa-a862-22e81b39bf50">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c0676c8c-1e6b-45df-ac20-35dce62f4821">
      <Text>My hand is fine.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1ca9c65c-e0b6-48f9-924a-f2e8c3d24532">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="013034e4-cc8e-4348-a1b2-bf896e7cf152">
      <Text>It's bleeding through—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f88c65cb-bffe-4114-85a2-f0d430a5c858">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9c341a8f-f3b6-4e0b-8967-7bd9e5baa85d">
      <Text>My hand is FINE. What is NOT fine is that I drove forty-five minutes from New York City to this—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d6f90314-a514-46f8-8912-2810b071fee9">
      <Text>He looks at the office.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0426f21b-aaef-4d75-a4c3-17e5b44655a4">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4009e087-995a-42b7-a6b8-dd8729e587c6">
      <Text>—establishment, to get a piece of public information, which is my RIGHT as a citizen of this country, and you are standing there telling me that the PUBLIC RECORD—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5c16f641-7c33-4351-89a4-231e31cdb556">
      <Text>He slams the hand down again. Full flat. The gauze sound is worse this time. Something has shifted in the wound.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3cea22b8-3a20-4d71-a03b-39152c5bd6d5">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d9b639ba-4ddc-4186-aecb-fd23ff71f43a">
      <Text>(pushing back from the counter slightly)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0fb05403-3822-4a7c-bda1-0c46eaf2e7dc">
      <Text>Sir, I need you to lower your voice—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8061c24b-56cf-4841-a472-f6584c7c63a1">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="63bb0fef-2e90-4292-a46b-3b9cc797d151">
      <Text>—is UNAVAILABLE because of some ADMINISTRATIVE—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fe0f4019-46b7-4e15-9f83-f868c56a0e3e">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e87750d7-3f65-4423-836d-d6795d137aca">
      <Text>Sir—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="04176fdd-e2ce-4fa0-95ff-983eb9836438">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4cb41b29-becc-4f55-a9a9-711dc8616a9f">
      <Text>—BACKLOG that I should somehow have ANTICIPATED and PLANNED AROUND when what I actually needed to plan around was the fact that someone TOOK—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="10dc4e4b-ef9f-494d-b18c-296feb88f972">
      <Text>The gauze is leaving a mark on the laminate now. A pale red print that blooms slightly at the edges.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="05503c5e-a63f-414d-8e65-4445d9125680">
      <Text>CAROL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7a364d4-6ab6-43b9-9569-82fd2e5e381d">
      <Text>Sir, you need to step back from the counter.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f7f6dd8f-de44-4db4-a440-69add6fd255c">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e8ecc12c-977d-423e-b845-a2fa98b5dad6">
      <Text>I will step back from the counter when you give me a NAME. ONE NAME. ON A DEED. That is a PUBLIC DOCUMENT. That is literally the PURPOSE of this OFFICE—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4edbd897-454e-4cf4-90d3-92821b690299">
      <Text>A hand lands on Tanner's shoulder. A very large hand. Attached to a very large arm. Attached to OFFICER DARNELL WASHINGTON, Sussex County Courthouse Security, six-foot-three, two hundred and forty pounds of absolutely unhurried authority. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="4edbd897-454e-4cf4-90d3-92821b690299">
      <Text>He has been moving across the room since the second hand-slam. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="cea24a39-53c4-46ef-aec3-9f6a2324f663">
      <Text>OFFICER WASHINGTON</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="083786eb-c5d1-4f1d-baad-eda680a71fba">
      <Text>(completely pleasant)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1deb30e2-e5a3-4068-9467-bf1d43a4ec3a">
      <Text>Sir. We're going to step outside.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="469b5801-e0b5-4a82-b394-42d2fc921dac">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5d10dff8-8040-41e4-b96c-f3de66a05d17">
      <Text>I'm in the middle of—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d726bab0-462a-4842-a0c9-ed50f0f85933">
      <Text>OFFICER WASHINGTON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ac6622a0-3029-4ec5-a053-cdd248d4fea4">
      <Text>We're going to step outside now.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e6d96a96-5d67-43bd-a187-dc42eb77f143">
      <Text>The hand moves from shoulder to collar. The other hand finds the back of Tanner's belt. This is no longer a suggestion.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5de346a2-e907-4368-af8b-95b63a536cec">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="afc2b8d2-f9af-49f6-8397-fdacfda54250">
      <Text>What are you— I'm a CITIZEN—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2d3c648a-80aa-43e0-98bf-28a5223a259a">
      <Text>OFFICER WASHINGTON</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="1779841d-286b-4887-8f1b-115f6a503a84">
      <Text>(already moving)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0043b90b-6bae-4c14-a4d5-92a7051b1076">
      <Text>Watch your step, sir.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="81d8e373-db2a-4c6d-a95e-bb96dbeec70c">
      <Text>Tanner's feet are off the ground. He is being walked toward the door with the brisk efficiency of a man who is equivalent to a geologic force. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="ef7fc0c5-9f3c-4e9a-87f7-98372056d85a">
      <Text>TANNER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b19868c8-5e16-4140-9e29-6ba5eaad388c">
      <Text>This is ASSAULT. This is— you can't— I have RIGHTS—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7119fd78-410f-4fd2-80eb-398eb6e55125">
      <Text>OFFICER WASHINGTON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fa55a0bd-1d06-4477-999d-79999a6193d7">
      <Text>You have the right to come back tomorrow, sir.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="33d5f1d9-a948-4a07-88b8-e20a2a10c245">
      <Text>The door opens.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8575e06c-2c1f-4221-9d15-5fc59b005305">
      <Text>And the New Jersey morning air receives Tanner </Text>
      <Text AdornmentStyle="-1">Sonnefeld</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e755368b-4268-47b1-a0d1-3b16d2538aa7">
      <Text>He lands on the steps outside of the office with prescribed indignity. The door closes behind him.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e755368b-4268-47b1-a0d1-3b16d2538aa7">
      <Text>He straightens. Adjusts his jacket with his good hand. Runs his fingers of his hand through his hair.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f537a955-134d-42a2-a9ce-5859608cbb15">
      <Text>The other hand, the gauze now fully saturated, a slow drip finding its way to the step below him.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="db2ae39a-de56-42be-82a2-7ab228e8265b">
      <Text>He looks at his phone. Pulls up Jimmy Fong's number.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="88461f0b-4773-45d9-837b-0936990aab52">
      <Text>Looks at it. Does not call it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0212d3ce-a58b-4507-8eac-6a7566cb73ae">
      <Text>He puts it back in his pocket. Walks down toward the Hummer. His reflection moving across the glass of the municipal buildings as he passes.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="36929b56-5334-40ab-bc26-3ca019cba5be">
      <SceneProperties Length="1 4/8" Page="28" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CLERK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JANET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. AT&amp;T STORE — VERNON TOWNSHIP — MORNING</Text>
    </Paragraph>
    <Paragraph Type="Action" id="343978e3-ee19-46d7-99a0-944521a605c9">
      <Text>The specific fluorescent democracy of a rural wireless retail location. Display phones on white pedestals. Promotional signage for a family plan featuring a stock photo family that has never had a problem.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="09d7f60b-04be-4c24-aa12-1cef4aeb851a">
      <Text>Janet McCort at the counter. The bedsheet gown.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c7d0fa5c-d2d3-4015-a94b-b4757e792c0e">
      <Text>The CLERK — mid-twenties, ponytail, lanyard, the energy of someone who took a job because it was near her apartment— is tapping through the final activation screen on a terminal behind the counter.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="52aac78a-1bbf-453c-9adc-f975e3dd4d3a">
      <Text>A new iPhone sits on the glass between them. White box open. The plastic peel still half-attached.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b4cb3f93-f1b9-4a22-9328-f2d51fc228b9">
      <Text>CLERK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1fd083a5-2e52-4a32-a334-bfa9963f5446">
      <Text>Okay so— this one will be activated on your current account. It'll just show up on next month's bill.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4f16c75a-ad76-4548-b782-1438d8ffce15">
      <Text>She taps. Waits.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e12a5803-d3ae-4ba2-b263-ad6b9016c193">
      <Text>CLERK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9007432c-681e-400c-8906-644b197b89e9">
      <Text>Are you absolutely sure you don't want it as a replacement for your old number? Because if you do it'll just sync all your old contacts, your messages, your photos— everything just comes right back over, it takes like two minutes and then it's basically like your old phone never—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0fd1542f-5fa3-467d-a825-c528d80dde5f">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fc0fbb88-af6f-4833-b34b-7a53ea15905d">
      <Text>I'm positive. Thank you. A totally new number. Fresh install. No sync.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="f01e4e78-5606-46e5-9c59-4f9c683fb360">
      <Text>(warm but final)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fc0fbb88-af6f-4833-b34b-7a53ea15905d">
      <Text>Please.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7b81cfe7-f85e-4aff-b8e4-a811d5aceeac">
      <Text>The clerk shrugs. She couldn't actually care less.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f8d053e3-2adf-409a-b43f-eb5fd94415bd">
      <Text>CLERK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fb85ad51-5814-4d2e-9393-bceec2bac809">
      <Text>Okay.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="653274ee-3878-4dc6-949a-0b77326a5ff5">
      <Text>She taps. The terminal thinks. The activation completes.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f10f8668-3fb3-47bb-b266-ad8117f99e91">
      <Text>The clerk tears the receipt from the printer. Slides it across the glass with the phone on top of it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2fb170e7-6152-4739-8d1d-b9f24c88270a">
      <Text>CLERK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="05197ac4-a154-47ab-a35c-c5c57beb294a">
      <Text>So this is your new number. It's on the receipt. You're live.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7cbc9300-5891-4074-8f18-fe1d1f78ac50">
      <Text>Janet picks up the phone. Holds it. The screen is dark. A clean device. Nothing on it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="332372c4-edf1-45c2-8d7e-0f28aa5cff2c">
      <Text>The clerk is already turning toward her terminal when she stops. Looking past Janet, through the plate glass storefront, at the curb.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3e63d0e9-7c41-4d87-81f3-9ee3b35db487">
      <Text>The 2019 Chevrolet Malibu. Dennis Pruitt behind the wheel, coffee in hand, specifically not looking at the store.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="df37654a-2205-4100-83a2-6795ef9d4588">
      <Text>CLERK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bec27cd3-1f45-44bc-ba0e-81f98ea17a9d">
      <Text>Is that—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="30d42a38-2c7a-41e0-bc18-69ec900deea1">
      <Text>She squints.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bcfb57fe-3812-457a-8018-388a54e6cc8a">
      <Text>CLERK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="59ead8ff-94f8-4d29-b20f-ffe0a385b4ce">
      <Text>Sorry— is there anything else I can help you with, or— your husband? Does he need anything?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a8bb1bcf-1041-4286-b7f3-4e8755ec954a">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e4b0310a-433a-4a51-8b1d-f080763b58dc">
      <Text>(the smile)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2eab53cf-4676-4311-aa00-3e7d8eae9fa9">
      <Text>He's not my husband.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="0c0c78fc-2562-4c94-81ec-7b883ccc377b">
      <SceneProperties Length="2/8" Page="29" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. AT&amp;T STORE — VERNON TOWNSHIP — CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4dd38af5-e5f3-4011-9eca-eb4e5eeba053">
      <Text>Janet through the door. The mid-morning air on bare arms. The bedsheet catching a gust and holding it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="70a75ef2-4059-4cd8-b073-8b51408b288e">
      <Text>The Malibu at the curb. Dennis straightening slightly as she emerges. The clipboard on the dash. The Sudoku book on the passenger seat.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="85572ece-f724-46b8-ad91-b8bf375d82c2">
      <Text>She crosses the sidewalk. Opens the passenger door. Moves the Sudoku book to the dash without asking. Sits. Closes it.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="8b8639cd-e993-4ec1-a94a-e6ca9b7dfb4d">
      <SceneProperties Length="2 2/8" Page="30" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DENNIS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JANET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. PRUITT'S MALIBU — CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="270c4d7a-4fb5-454c-b803-a0ca62b68098">
      <Text>She holds the iPhone out to him. Face up. The full gesture of it— both hands, offering, like she is handing him something precious.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b10dfe47-3b4e-4815-ba63-8012ce11347f">
      <Text>He takes it. Turns it over. Inspects the screen. Swipes through the empty home screens— no apps downloaded, no accounts signed in, no history of any kind. Factory default. He checks Settings. Checks Messages. Checks the call log. Empty. Empty. Empty.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5bb33c65-85f2-4249-9250-e97733d7b6b6">
      <Text>He is thorough. She lets him be thorough.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="30a6d235-2f0b-49cf-a6ef-f4974e29ff7b">
      <Text>He opens Contacts. The list is blank. He types with his thumbs, one letter at a time, the specific hunt-and-peck.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a31e20e4-81fa-4ccf-9ffe-36a5dd5f14ca">
      <Text>DENNIS PRUITT — SUSSEX COUNTY PRETRIAL SERVICES</Text>
    </Paragraph>
    <Paragraph Type="Action" id="59c2f543-3946-4282-b192-eb6d02dba3f3">
      <Text>He saves it. Holds the phone for a moment. Looks at his name— the only name, the first name, the only entry in the only phone she has— and something moves in his face that he would call satisfaction and that a more honest accounting would call hunger.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="87eabb5a-fc0d-4b5d-86eb-2eacc80317bb">
      <Text>He hands it back.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cc44ff7d-f4d5-4a9c-8a57-b9d7721db047">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e41e5d6d-9771-4f98-9628-cfe983514a46">
      <Text>You'll want to set a passcode.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="85726c84-9bb0-4ad3-a2b4-d48db1c6953f">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d1daf5a0-f9d7-48b8-9c93-231ac2c4794e">
      <Text>What should it be?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="39cb8368-904b-4f4e-99c4-1bab13c0eb82">
      <Text>She asks it like she's asking him. Like the answer belongs to him. Like the phone belongs to him.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7f7fb27b-e71a-4ba5-a6a7-712ffd9d4894">
      <Text>Dennis opens his mouth. Closes it. Considers.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="032e034b-1324-4903-8f05-e60d36e24c30">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="41de7659-3c27-4e0b-be3a-496a11ac17b0">
      <Text>Something you'll remember.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e0efc3cf-5f17-47c4-bbc5-01a7f0dccaba">
      <Text>Janet looks at him. Holds his eyes. The full weight of her attention— lands on Dennis and he does not have the mental infrastructure to understand it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b5e70974-f46c-401f-b140-40d6341b0e0a">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="38970dc9-988c-4adb-a934-362f99052ca7">
      <Text>(quiet)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1a40aef2-74e0-4570-99e6-03269005357c">
      <Text>My hero.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4ef1aa51-d59e-449b-aa38-5f87e6753f5e">
      <Text>A beat.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5e09d4ed-df76-4e2d-ba91-e5a96c3e589a">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="679e28c3-c543-4b62-a9b9-8d87ce72731c">
      <Text>M-Y-H-E-R-O. Six characters. I'll remember that.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="111bb5f2-e98f-499c-8ec2-bc93b5109c94">
      <Text>Dennis' hands are on the steering wheel because his hands need to be holding something.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="61abe8f9-50ad-4a13-af9a-3169be65a8b3">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="240bbdd3-463b-4da9-a9b0-a65f5f8b1c80">
      <Text>(clearing his throat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="64d2cb6a-16fe-4512-8b95-0591c69f969e">
      <Text>That's— that works.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4f996afc-7be9-45db-acbf-904d8975953b">
      <Text>She types it in. Shows him the lock screen. Shows him the passcode prompt. Types it again. The phone unlocks. She holds it up for him to see.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b57c10ff-44b2-4d09-a8e9-c91efaefcee4">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bcf8b403-386b-4ff2-9c89-d469f6b181fb">
      <Text>No encryption. No apps. Nothing between you and me. Fully exposed.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="71aea905-9c7e-431e-a6aa-e0dbf36fcab8">
      <Text>She looks at him. Tilts her head. Fractionally.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c357de80-327e-468a-bfc4-9a2eaf68a4b1">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="83601a0f-3705-432e-8151-8a6f8128aed7">
      <Text>But- shouldn’t we- you and me- have something- private for us to- chat- personally?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a2f7abac-04e2-4ec3-93f9-5d5f0eafa6f6">
      <Text>The word </Text>
      <Text Style="Italic">personally</Text>
      <Text> does something to the air in the Malibu that the Malibu was not built to contain.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1df4c12f-1cf8-41a1-a081-b4419e51cbcd">
      <Text>Dennis's jaw works. He pulls the clipboard seemingly inexplicably, sets it in his lap. His eyes move from her face to the windshield to the clipboard and back to her face.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9a041a3e-48ca-4d08-b00b-7257abf8a704">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="443a06f8-4080-4f12-93b7-eef3835430cc">
      <Text>(the professional register, barely)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="388cde67-ae72-462f-8125-ee16c4fa88cd">
      <Text>The courts wouldn't— allow that.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="37101f78-9556-42f4-96c2-0fe92cedf6bd">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b06f9eb2-7409-459b-b73a-134e1dc42a47">
      <Text>Of course. Stupid of them.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c8fa3cbf-e896-4845-b307-2a65369e59ae">
      <Text>She puts the phone in her lap. Hands folded over it. She just waits. The silence hangs. His clipboard remains awkward in his lap.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="34719de8-3679-4326-8428-93ce4b75e0a8">
      <Text>Dennis puts the car in drive.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5473d432-178b-41bf-be8e-8e8a4103e2a1">
      <Text>He pulls out.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="742f073e-e9f3-4152-9292-8652881ef232">
      <Text>He does not check the mirror. He pulls into a U-turn with the spatial awareness of a man whose blood supply has been recently and comprehensively rerouted from his brain to another location.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="260313b3-021a-4974-8192-eaf7997e4870">
      <Text>An NJ TRANSIT BUS lays on its horn— the full civic authority of twelve tons of public transportation, swerving across the center line, missing the Malibu's front quarter panel by the margin you'd measure in layers of paint.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="14f544c4-14b4-4510-9796-27ab9676f1f1">
      <Text>Dennis slams the brakes. Janet's hand catches the dash.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2610c2d7-f66f-49e0-92f1-af308036dad9">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e6efe02f-e890-4f18-83d6-177c1ea389d4">
      <Text>(out the window, full volume)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3d0a7655-4a36-49d7-a664-924d482224c2">
      <Text>ASSHOLE!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d8aedd90-5edc-4bfa-9b65-d5d6c4a6a29a">
      <Text>The bus is already past. Completely in the right. Had the right of way by every measure known to traffic law and God. Through the rear window— the back of the bus, the route number, the ad for a personal injury attorney that is, under the circumstances, doing exactly its job.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="abf50388-da95-4a25-8c86-878d2e6b6e5d">
      <SceneProperties Length="2/8" Page="32" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. NJ TRANSIT BUS — SAME</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4b11b1ed-32e5-48e6-aa3e-1b9e581ddd75">
      <Text>Chuckles head bounces off the glass and smacks back into it— hard. The specific crack of skull on transit window that every bus rider has experienced as the bus serves. He's awake. Hands up. No idea where he is.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6d168648-1dce-40a1-af23-170f5a7a6e38">
      <Text>He touches his forehead. Looks out the window. Trees. A strip mall. New Jersey.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ce037e6e-ca2c-4dd2-9907-a084b21cb62c">
      <Text>He puts his head back against the glass. Closes his eyes.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="a5ed46bf-ff9a-467a-93a8-50630298e946">
      <SceneProperties Length="1" Page="32" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DENNIS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. PRUITT'S MALIBU — CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c2a04022-4cab-4695-8bcb-0fafa97dbd16">
      <Text>Dennis finishes the U-turn. His jaw set. His hands on the wheel at ten and two with the overcorrection of a man pretending the last four seconds didn't happen.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e97770c6-2e19-4125-be10-a63726b2258e">
      <Text>He pulls to the curb on the opposite side of the street. The passenger-side front rim grinds into the concrete with a sound that is deeply personal to the hubcap and permanent to the alloy.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1b9ab9fa-2874-4a79-b48a-f9a6e6b3161c">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="3de4af31-3714-4ca6-ba54-79690483c139">
      <Text>(not looking at the curb)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d3cbe45a-d375-4b16-932c-9f2e17c3bf9a">
      <Text>They changed this road. The lanes used to be—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8f05514e-4998-4186-b873-ce4cfdd21845">
      <Text>He gestures vaguely at the street.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e041408c-d728-41f6-a548-3380cfd35716">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d11ab2ed-84cb-471b-9294-7cf93ee62c81">
      <Text>—different.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1017783a-89f4-40dd-8e45-d0688f481caa">
      <Text>He kills the engine. Gets out. Walks around the front of the car in a misplaced attempt at chivalry, and opens Janet's door.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b06d4b75-9016-4264-a008-20b62128cbd2">
      <Text>She steps out. The bedsheet on the sidewalk. The morning air.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="de4de7a7-8d45-4466-8bb3-7b102f330430">
      <Text>She is looking at him- confused trying to understand why they didn’t just use the crosswalk and why they are now here.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2b7d8251-0f06-4a22-a6b1-83a23b16fa2e">
      <Text>Then she sees it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c7d8eb5b-40c4-49ad-b143-df231679fa90">
      <Text>The door. Glass, street-level, between a State Farm office and a place that does notary and passport photos. A small print shop sign:</Text>
    </Paragraph>
    <Paragraph Type="Action" id="41a1a93f-eee0-4773-a02f-f1b45c74bc78">
      <Text AdornmentStyle="-1">VÃSQUEZ-REYES</Text>
      <Text> FAMILY LAW</Text>
    </Paragraph>
    <Paragraph Type="Action" id="be490afc-6e31-4e41-ab88-fd19e409b121">
      <Text>Janet looks at the sign. Looks at Dennis. Looks at the sign.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0f07d7c9-40b5-4fab-926b-c47c4652ffba">
      <Text>Dennis holds the door open. His hand on the glass. The other hand gesturing her through.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6a379582-e771-4173-9240-79a2b3937c81">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c356968b-d253-4abe-a1e5-cbba460bd5ae">
      <Text>After you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="49156612-301d-43be-95f5-c726b24d8cbf">
      <Text>Janet steps through. The bedsheet crossing the threshold. The phone in her hand.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d6c009be-0cd5-44f7-b1ae-763ecceb90f6">
      <Text>Dennis follows her in. His hand finding the small of her back as the door closes behind them.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8dc343e6-38cc-44cb-b06b-128d92f72376">
      <Text>She almost feels bad for him. Almost.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="66d1b9db-35ce-4a30-aae2-301479f186fe">
      <SceneProperties Length="5/8" Page="33" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DENNIS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. VÁSQUEZ-REYES FAMILY LAW, LLC — RECEPTION — CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1c51771e-654c-4607-ad64-462de936de2f">
      <Text>The office is small and clean. A reception area that doubles as a workspace. Betty at the desk — fifties, reading glasses on a chain.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1c6cb562-b9cd-43d9-8592-0e2a668da7f1">
      <Text>The rubber plant. The Sotomayor print. The specific look of a space that was built on a budget and maintained on principle.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3942e4ad-d3ec-4033-b2f6-9b1ef57f1a84">
      <Text>Dennis has already passed Betty without acknowledgment. He is moving through the reception area toward the inner office door with the momentum of a man who does not believe waiting rooms as applying to him.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ffd0d7fd-658f-4102-9052-47a9ac457453">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7428df47-cc5c-4978-95b0-8005f740743e">
      <Text>(over his shoulder, to the room generally)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dc7032ff-1b2e-4ee7-8085-661914cf4ec8">
      <Text>Maria? Dennis Pruitt, Sussex County Pretrial. I left a VM this morning.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="252937ad-8257-4a2a-ab40-20c7e3d68ed3">
      <Text>Betty looks at Janet. At the bedsheet. At Dennis's back already at the back office door. At Janet again.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="85ed8b31-98d4-47c3-99e9-9c8d09f3bb9b">
      <Text>Janet gives her a look that contains an entire language. Betty receives it. Understands what a woman in need looks like.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="e633f596-a70d-4349-96f5-ca56ab1e3d29">
      <SceneProperties Length="7 2/8" Page="34" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DENNIS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JANET">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARIA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. VÁSQUEZ-REYES FAMILY LAW — MARIA'S OFFICE — CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="96006ed8-9743-426b-aeb8-2e4b1e13152f">
      <Text>MARIA ELENA VÁSQUEZ-REYES behind her desk. A legal pad. A pen. She is already standing because the door opened without a knock.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="23fbc89d-e5d2-425a-8911-92c8c7dd39ef">
      <Text>Dennis enters first. Janet behind him. His hand finds the small of her back again.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dee09ff2-1411-471e-99be-6a1ff8ce4e3f">
      <Text>Maria sees the hand. Files it as he settles into the client chair without being invited, the clipboard on his knee.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2509f60f-a588-450a-a508-4d1ac24a6527">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d6b3d67c-2666-4d24-9805-02d8b38f4134">
      <Text>So. Maria. Appreciate you fitting us in on short notice. I know this isn't your usual—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a0e65ed6-12bf-4427-acc1-7cd44ab26d3d">
      <Text>He gestures at Janet. The bedsheet. The ankle monitor visible at the hem.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="67850c0e-4a3b-4ee6-8704-5cf63ae2b61e">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f09f3b86-455e-4d91-aefe-e6222d796aa9">
      <Text>—clientele. But the situation is what it is. Mrs. McCort here is under my supervision— my personal supervision— and we've got a good working relationship going. A real good one. But the courts are going to want to see that she's got, you know—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3c4677a4-82c4-4dc1-95cc-be3d491ec29a">
      <Text>He waves his hand.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="031bde5b-3995-43ab-af87-9753e6d6b680">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="517560d9-b21c-4aa8-ac97-ea2fca34332d">
      <Text>—a bar member. On paper at least. Somebody who can file the motions, dot the i's, make it look official. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="a1f79865-8bf5-4490-827a-eb6a84381f1f">
      <Text>(condescending)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="517560d9-b21c-4aa8-ac97-ea2fca34332d">
      <Text>You know how it is.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="93ab3f25-40c4-4f90-8223-ee8afc35ed94">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b2d2274b-35b6-4c47-bbdd-ef363379b3f2">
      <Text>Now I want to be clear— Janet and I are handling her situation together. She's in good hands. What we need from you is really more of a— administrative D.E.I support role. Clerical. Legal name on the filings. That type of thing.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8d8a468d-81e5-44ae-a282-fc3e32ed217c">
      <Text>Maria has not sat down. She has not spoken. She has been watching Dennis talk.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="36795401-7e9c-4190-b242-8a91ca7e94da">
      <Text>Dennis is still going.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d4b95e4b-4724-47e4-a517-445698c10b65">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="65a6490f-dda8-4922-8208-259ff304c5d2">
      <Text>I've walked her through her conditions, her compliance framework, what she needs to be doing day to day. She and I have an understanding. A real productive understanding. So what I'm thinking is you and I coordinate— I'll keep you in the loop on the supervisory side, you handle the paperwork side, and between the two of us we make sure Janet here is—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fdb96bad-4b45-4a77-92f3-e6b2449eba44">
      <Text>He looks at Janet. The warmth. The specific possession of it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="006d2ce1-8cd0-42a6-bc5e-e401199bad7e">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e0e2889f-6c22-44cf-8572-028dd5cbda8d">
      <Text>—taken care of.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7b14884f-0533-45a6-b9ef-bab9e00879aa">
      <Text>Maria looks at Dennis. She looks at his hand, which moves from Janet’s back to the arm of the chair like he’s</Text>
      <Text Font="Sans Devanagari Final Draft"> </Text>
      <Text>claiming it too. She looks at his clipboard. She looks at his polo, freshly pressed, the Sussex County seal. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="28ce018f-01b8-431b-906b-065eb76a0d59">
      <Text>She is looking at Janet.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a050be5d-3e08-4258-948c-492147820a33">
      <Text>Janet is standing just inside the door. The bedsheet. To Maria, Janet looks terrified in the way Maria has seen so many women try not to.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="02ba23b1-f52f-48f9-be73-61988c34a9c4">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="5994b8b1-fe3b-4a7b-ac94-7fe3b48596d7">
      <Text>(quiet, direct, to Janet)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b23890f1-b37a-4a87-b75f-6e71cb7f3bcf">
      <Text>Do you need representation?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d6988b75-1a76-439a-aee1-c110edc2d9a8">
      <Text>The frequency of what is happening in this office shifts in that instant from Dennis’ meeting to something else.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c2531934-5e65-4b44-bb26-f4680bfcf481">
      <Text>Dennis opens his mouth.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ec1abc3e-4214-4ea4-9f6f-6640e4482ab0">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="dabfb3bc-2d92-4622-84e1-6fdc242def71">
      <Text>(to Maria, not to Dennis)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="22143f9e-cff4-489c-b4c0-4969124f2950">
      <Text>Yes.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="284ca0af-54a7-45cf-9f69-983cd1d50166">
      <Text>One word. No warmth in it. No performance. The flattest, cleanest syllable Janet has produced in a very long time.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c775f9d6-211d-495a-90e9-5e9665a63dca">
      <Text>Maria nods once.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="90aaff34-7213-4c9d-96df-f181057e17c9">
      <Text>She turns to Dennis.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8f58efa6-0986-4b19-83c8-dae29bc9795e">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9d271ae1-f171-4654-8a98-6261bc6037ee">
      <Text>Mr. Pruitt. Thank you for the referral. I have a new client. You can wait outside.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6af6f34e-0bd2-43bb-9228-da44d28f670f">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f95cc446-caeb-4e29-9925-ecced3d106e4">
      <Text>Now hold on—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="67fc151c-43b8-4b34-aed8-4cb59e70a614">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="4923c167-d9eb-498c-8aba-43f194591900">
      <Text>(without raising her voice)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="95cc3def-ecf8-49a2-baa7-02cb805051b8">
      <Text>Mrs. McCort is now represented by counsel. Any further communication regarding her case, her conditions, her schedule, or her situation goes through me. Not through you. Through me. That's effective immediately.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="63b491d7-5fab-4f4f-8647-d0239ee37b5b">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="4ae0cdcb-4ea1-46ea-a601-41d2663f3677">
      <Text>(the smile, thinner now)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="68843cb2-9619-4859-a7c9-f94b883d6e69">
      <Text>Maria, I don't think you understand the supervisory relationship—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4c6aca18-8cfb-4190-b771-4ec608a9798c">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9a7b5912-1cd2-4cd7-9a1f-591e1a6832fe">
      <Text>I understand the supervisory relationship. I also understand the ethical boundaries of that relationship, which I'm going to assume you understand as well, because the alternative would be a conversation neither of us wants to have this early in the morning. And it is Ms. Vasquez-Reyes, please.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3faf72b2-11c0-4b8b-b05b-2c6588fb4d56">
      <Text>She holds his eyes. She does not blink.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7f0a8602-6762-4ccf-a6ed-381f69322a68">
      <Text>Dennis's jaw works. The clipboard in his hand. The room that was his seconds ago is gone and the mechanics of how that happened are not fully understood by him.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="72382c0b-61a8-4761-88c1-3fc1dbb2ca79">
      <Text>He looks at Janet.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d5f1485b-4c03-483f-b0d7-453c9f68663c">
      <Text>Janet’s hand finds his forearm. Light. The specific gesture.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="26123530-6b36-4e4f-8f75-1e585f43a284">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="0ce74225-ae21-4833-8ab4-908b9d8f9720">
      <Text>(soft, just for him)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bb70f3cb-7d26-4edf-98d8-ba52de01c819">
      <Text>Would you let us talk? Just for a few minutes. Girl stuff. Legal things I wouldn't want to bore you with. I’m sure you have very important </Text>
      <Text>official</Text>
      <Text> business that needs you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1d7dde81-b31b-4d95-9227-87022e043a33">
      <Text>She squeezes his arm.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f5719f92-85f5-41aa-aa6c-fc944fcf0f3d">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f9e70ea8-a4f5-40c1-bc1c-bb107c4223b8">
      <Text>I'll be right out. I promise.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="52d0d4fc-021c-47ed-b692-4a491d197298">
      <Text>Dennis looks at the hand on his arm. Looks at Janet's face. Looks at Maria behind the desk.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f01722e6-6ba9-46a3-818a-4e160d3a7b6d">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d659646a-2d7d-41b3-96e6-0d6a13279fda">
      <Text>(to Janet, not to Maria)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6855e040-b039-4d39-a533-eb368d18f7b0">
      <Text>I'll be in the car.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a741300c-53cb-42d2-a2f1-616b2fb47c81">
      <Text>He stands. Collects the clipboard. Adjusts the polo. He walks toward the door with the indignity of a man who has chosen to leave rather than one being thrown out.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9b78a0af-91c1-4c17-83a9-f170b1f9947c">
      <Text>At the door he turns.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="de54cc8a-418a-47e9-a98f-8920b44dfd40">
      <Text>DENNIS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="036f6ffd-d0ac-4b6d-b254-b021a11859d4">
      <Text>(to Maria, pleasant, the smile)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="359f2889-bce6-4a14-b7b0-87c664226a99">
      <Text>I'll be in touch.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dcc9a05b-d603-4bf7-bd46-e1ecc7e14c6c">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cc8f5eb0-30d4-4746-ab0e-e6d47b5409cc">
      <Text>Betty will give you my card, you will need to contact me if you want to speak to my client.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="05440428-4ba7-4450-b70f-1983894fd375">
      <Text>Dennis leaves. The door closes. His footsteps through the reception area. Betty's chair not moving. The front door. The street sounds. Gone.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9d03c30c-fc39-4bfa-8f55-d5aa44357d38">
      <Text>Maria sits. Gestures to the chair Dennis vacated.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3e9a1970-dff2-435c-8cd0-1d4cd9669039">
      <Text>Janet sits. The bedsheet arranges itself around her. She folds her hands in her lap.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="34a7c4f4-45c8-4642-b04a-99429ceb43c6">
      <Text>The office holds them. The rubber plant. The Ruth Bader Ginsburg print overlooking these two women in a room the size of a parking space.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ce3a8fb2-7ce5-4cdb-a360-eef82c18b52d">
      <Text>Maria waits.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="06671455-e1e6-41db-a357-a723fbc47ed5">
      <Text>Janet looks at her hands. At the phone. At the wall behind Maria's head. At the diplomas she can read from here- </Text>
      <Text Font="Sans Devanagari Final Draft"> </Text>
      <Text>both of them, the Rutgers, the Seton Hall, both New York and New Jersey bar admissions framed side by side.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3c36e76f-d0b7-4449-af9a-5939c66b5a61">
      <Text>She looks at Maria. Exhales long and hard.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a8386c5c-271e-4521-a517-063a40c8f6d0">
      <Text>Then-</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b22c09a7-3de3-4e47-9cc3-5677d98f4ca1">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9491243f-0185-4350-8d01-167f44437e30">
      <Text>My husband is Kevin McCort. We were both arrested early yesterday morning in Manhattan. Fraud. Martin something. Me on conspiracy for something I have no idea what is. The judge is restricting us to the Playboy hotel thing near here. We both have ankle monitors.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8bd53956-0e27-4457-b304-92a0801251b7">
      <Text>This rattles out of her in a kind of desperation of a person trying to get it all out at once but doesn’t completely understand how or why it’s all happening.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6db8392f-29ca-4736-8818-531df49a1712">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="758bb7a2-397d-4571-87fd-19148b9e6c16">
      <Text>We have an attorney. Hunter Reid. He represents Kevin. He does not represent me. He has been— extraordinary. But he is not my lawyer and I need a lawyer. He has said we have a co-defendant restriction or something and my husband and I cannot discuss anything related to the case. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="2d682e64-145c-4972-b262-74dd7dc5d5f4">
      <Text>(voice finally cracking)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="758bb7a2-397d-4571-87fd-19148b9e6c16">
      <Text>I’m totally fucked and my marriage is over. which is everything.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e4e603bd-fc40-48da-b5e4-a18cb9c6acc7">
      <Text>Maria has been writing. Not looking up. Until that last part.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0d062eee-bd95-495c-9fe9-b03f6f6e444e">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5de5d49c-e6f9-4e07-bf92-3d4af64c4488">
      <Text>There is a photograph on my old phone. Several photographs. Messages from a man named Chet Masters and several others. Chet is Kevin's fraternity brother from Princeton. He is also Kevin's boss. He is the CEO of the company Kevin was COO of before they accused him and we were arrested.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ec45ca73-7f71-4fac-ae59-58d070772e93">
      <Text>A beat.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="06219196-762d-478a-ae1b-d71e8f80aeee">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="af169a93-b53d-4ed3-bc49-138f2d384468">
      <Text>The photographs are— not good.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ea9a656e-1917-4ad9-bc8f-b3a763e885bf">
      <Text>Maria's pen stops. She sits back.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f8a96f74-4560-414c-8b82-cc8361d464d8">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8187cbf4-43fe-4923-9b79-bfb531359886">
      <Text>When the cops seized our phones, my phone was taken. But my son— he's fourteen, he's very good with technology— he did something with the phones in the car on the drive up here. I don't fully understand. What I do understand is that all my message history, my contacts, all of it— synced to Hunter's phone.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="019502dd-fa05-4a41-983c-1ce4386d5c00">
      <Text>Maria sets the pen down.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b50786f3-581c-46f3-a7e9-30e677aeaa34">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f108f1f8-2191-42c5-8d3d-e8679420d33f">
      <Text>And I saw my husband see it—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="20d26386-9068-4add-af88-aad8449e05d6">
      <Text>She stops. Recalibrates.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6afa0930-d545-4fa4-822a-488d363ca76d">
      <Text>Maria is very still.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8cd8f469-43ee-4d6d-a20c-a51c0f0c1ce6">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4d3e7843-8f13-4ed7-bddd-e6615e56578f">
      <Text>In the car. I don't know how much. He hasn't said anything. He can't say anything. We can't talk about it. We are in the same building, sleeping on the same floor, and we cannot have the conversation that is sitting between us because the judge says we can’t talk about anything or anyone involved in the case and every word between us about it is a potential violation.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e6cb0de5-2ae6-46dd-b013-78f6fbca0cd4">
      <Text>She looks at her hands.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9c1efe1e-342e-43dc-b069-bbf88d6a93a2">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="ea291e13-1667-40de-9c40-46dfe2c87640">
      <Text>(quiet)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a64bf85e-0b38-45b7-bcf1-74ac68e7b321">
      <Text>My husband of twenty-two years has just found out that I've been fucking his fraternity brother. who is also a witness in the cases against us.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="20ded8c6-149a-4ea3-a417-aff0b4a1f043">
      <Text>Maria picks up the pen.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7867bdbf-3699-4888-96ca-b1f4e4e832ab">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d3e1602d-4f6a-42dd-b5ce-829aba5b1a7d">
      <Text>How long has this been going on. With Chet.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0a8405e4-47fd-4d9a-a556-cfca08cd588d">
      <Text>Janet looks at her. The mask is not on. It has not been on since the door closed. What is underneath it is a woman who is tired in a way that sleep does not address.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d8d7e30d-c864-40e5-8428-60c6a24c95ff">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="231be97d-4e6a-4a29-bc01-acb8e10c52dd">
      <Text>It never stopped.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="68e6dcaf-ab41-494f-a587-01504e2d520f">
      <Text>A beat.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8e9350dc-aa67-4b63-aacf-bcbd3eeff15d">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c3858770-ab8c-433a-8b68-b236eeaabe45">
      <Text>It started the night I met Kevin. At the party. Chet was-</Text>
      <Text Font="Sans Devanagari Final Draft"> </Text>
      <Text>before Kevin. That same night.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bc5508cb-1dab-4e38-ab12-e4065cdc1cc7">
      <Text>Maria writes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b132a462-434f-4705-a95c-931041602f1e">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="719585b1-5e58-45e6-a08f-795f6dc9f071">
      <Text>And Kevin never knew that you were with this guy before you met?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fe662662-d8a0-4d47-92d1-060e77cac5df">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ef094749-8108-4962-bd29-2c6c7f9b66e7">
      <Text>Kevin never asked.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3abe45b5-67ae-4c66-a580-57c137e1fa1d">
      <Text>The room holds it. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="3eb59c42-73bb-49d0-b184-041c79adb038">
      <Text>Maria looks at her notes. Looks at Janet.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3782a8db-d6c5-446e-a45a-fcf5dd5b688c">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="09f68058-430a-4bf9-83f5-192e5e42ddae">
      <Text>Is there anything else I should know right now? Before we go any further.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e6943a5b-ebdc-4e00-b680-863233d42576">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="563cd357-00af-4381-a475-dd213d13128b">
      <Text>(burst of tears and laughter)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6071d869-2d0b-4b6f-93ff-7eab9f4272a3">
      <Text>Hah! I don’t have any money to pay you.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d791cac1-c9fd-4ab1-8767-bba401e9266a">
      <Text>Janet looks at her. A long beat. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="a82f9673-3457-4003-8426-b8f023fd3ecc">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a4a52cb7-0ae0-46fc-b6c6-9021c03c755c">
      <Text>Eh, we’ll figure that part out later. Anything else?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d791cac1-c9fd-4ab1-8767-bba401e9266a">
      <Text>Maria leans back. Takes off the glasses. Sets them on the desk.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2d511cbc-9939-41f0-ba58-c0ea08a6d9fc">
      <Text>JANET</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ff334432-e157-40e5-a3f5-c5c1886e010f">
      <Text>How much time do you have?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cee8b840-09be-4404-b70b-ff8bff758745">
      <Text>MARIA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="ab38a2f9-b656-41d5-a6f2-0e64a642adac">
      <Text>(shrugging)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2b3db6c3-6cb4-446f-acad-28cd8b347e5f">
      <Text>I have as much time as you need.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c9d4ea42-47b6-4acd-8b66-4249d3583061">
      <Text>EXT. ROUTE 94 — McAFEE — MORNING</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e2b3148b-4fab-432b-bb73-3bb9c22df987">
      <Text>An NJ Transit bus pulls to the shoulder at a stop that is barely a stop — a pole, a sign, a patch of gravel. The door folds open. Chuckles steps down with his duffel.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="94c1ecec-aa7a-4e4b-9a5f-1ca7b70118bc">
      <Text>The bus pulls away. The diesel hangs in the cold air and thins.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2288728e-9f5b-4aae-b334-cc9e41f36d9d">
      <Text>He stands on the shoulder of a two-lane road in rural New Jersey. Trees. A gas station with one car at the pump. The sun fully up but not yet warm. Eight in the morning in a place that doesn't care what time it is.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="620e9992-69a8-415d-889d-ebd068a35f63">
      <Text>He pulls out his phone. The pin drop Jaz sent him. A red pin in a green void. No name, no note, no context. Just coordinates.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="db4dcde2-8854-4b84-b51d-632f18e85133">
      <Text>He'd Googled the address somewhere around </Text>
      <Text AdornmentStyle="-1">Parsippany</Text>
      <Text>. The results were not encouraging. A TripAdvisor page with no recent reviews. A Wikipedia entry with a photo from 1972. A Reddit thread titled "</Text>
      <Text AdornmentStyle="-1">Urbex</Text>
      <Text>: Playboy Resort NJ — anyone been inside?" with four comments and a locked post.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d5a47924-ba52-42ff-a4ea-3fd5ad94f99b">
      <Text>He looks up from the phone. Looks both directions. Neither of them matches anything on the screen.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bc0209e2-8b3e-40c9-855b-a507a1795f19">
      <Text>Across the road: THE GEORGE INN. An old brick stagecoach inn that has been standing on this corner since before anyone needed a reason to explain why. Half locals bar, half liquor store. A chalkboard in the window advertising Mexican specials that no one has ever ordered twice. A single light on inside. The parking lot empty except for a maroon Buick </Text>
      <Text AdornmentStyle="-1">LeSabre</Text>
      <Text> with a dent in the quarter panel that has been there long enough to have its own patina.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="576485ff-92ab-4c91-b50e-6a7ad1561b6a">
      <Text>Chuckles crosses.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="b095b158-dcbc-416f-85a9-1a9357851215">
      <SceneProperties Length="2 4/8" Page="41" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CHUCKLES">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GLADYS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. THE GEORGE INN — PARKING LOT — CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c02c7d96-d436-4856-8fef-d24a90fc059d">
      <Text>GLADYS is on the side steps near the kitchen entrance. Sixty-something. The kind of body that has been standing behind a bar for forty-five years and has settled into a permanent argument with gravity. Bleached hair the color of a warning. Dark eyeliner applied with the confidence of someone who decided what looked good in 1981 and has not revisited the question since.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="141d74fe-8b1a-4340-a299-a84e6ed4e0ea">
      <Text>She's smoking. A Marlboro Light 100. The long ones. She holds it between her first two fingers close to the filter, elbow tucked, the other arm crossed beneath her chest. The posture of a woman who has smoked ten thousand cigarettes in this exact spot.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="06b37b5e-a30f-4780-a5f1-5260b3d751ca">
      <Text>Chuckles approaches. The Gig and duffel bag on his shoulders. The jaw working as the last of his coke wears off.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6beab2c6-1931-4b36-a9a8-50d8e500883f">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="95e0b630-2634-4a1f-b541-7746d08e5469">
      <Text>Hey. Morning. Sorry to bother you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f4d96fdc-684c-47b5-8be2-76197745f898">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="c941bf71-1056-4308-af92-b58294b75e39">
      <Text>(looking at him)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6ad1636a-7047-4ab5-b465-06d0ca03f659">
      <Text>Kitchen's not on yet.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6e5f6a18-b359-4d4e-a030-fb9cfa8a721b">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e7a8a254-9636-4b8c-bd55-2ced22c24fd5">
      <Text>No, I'm not— I'm trying to find this place.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="985be29c-e2bd-4b98-a026-9fe9227e2e6b">
      <Text>He holds up the phone. The pin drop. She leans in. Squints.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="849914d1-c081-4aaa-981e-7d7345937bbc">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d4598b26-89b1-4259-abab-3ba8cbfd24db">
      <Text>I think it's a building? Up on five-fifteen? Some old resort.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ed8005b8-e82c-4a79-bfd7-343db8707f12">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="bad1511f-01c0-49fb-b982-74a77c2be26b">
      <Text>(the drag stops halfway to her mouth)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="db091dfa-4faf-4781-8cae-0a9b14f16104">
      <Text>The Playboy?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a1a8958d-15df-4c38-9197-3862fde5af33">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6c323577-7dcc-41b2-a78b-26e45c34339f">
      <Text>Maybe. I Googled the address on the bus and that's what came up. I don't really know what it—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c14a035b-e5f7-4e72-b1fc-db8bd7000f29">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f013f6cc-0e6c-4e63-9877-f3d49ca9055f">
      <Text>Oh, I know what it is.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a1fb446a-081f-4ad2-a09f-f455a3bff3f6">
      <Text>She takes the drag. Something shifts in her face. Not nostalgia exactly. a old spark in her eye.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c37c2c3a-81f6-4011-b979-a48a52c5aecf">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b913800a-4b08-4408-89ed-df26c8efcb21">
      <Text>I used to work up there. Back when it was something.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7f01179d-cd62-4b36-8f8a-d51cdc64d2b5">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="43f9809b-cc93-416c-8a81-5000b572fd9d">
      <Text>Like— at the bar?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b16d2fce-dc05-4e4e-845f-3424fae91998">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="43152d82-3414-4893-8190-c9ff7fd3efe6">
      <Text>(a look)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ddc71473-d65f-4ccc-bdba-3e8a538be638">
      <Text>Honey, I wasn't behind the bar. I was on the floor. Ears and tail. The whole thing.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="48bf50bb-5998-4da7-a9e1-df436c66ce4c">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="21431283-0650-4239-bd11-cdc10abb6dd3">
      <Text>I was twenty-two. Hundred and eighteen pounds. Those Rat Pack boys used to have a field day with this little package.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f0b29c7e-d20a-4b02-a5b0-525aa499311d">
      <Text>She takes another drag. Looks at the parking lot. At the Buick. At the morning.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4b9772ca-419a-41eb-b19a-f6003de77bf5">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="46bd6cb3-64e7-4e5b-8535-99ac3e7f7400">
      <Text>That was a long time ago.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="82e70682-adae-44c2-8d9e-eaee3b0647e6">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d2a84c16-edd3-4afc-b662-abc0f1a23926">
      <Text>(genuine)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b613f45d-132d-481b-a06e-099376331155">
      <Text>No shit.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a7f6a751-37a2-4df0-9630-0d1b644eb798">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="94aa2116-2c41-461e-8ed1-1fe1b972aa13">
      <Text>(sharp look — then a laugh, short, real)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1370c46b-53e7-419e-bff0-c16b52c2886e">
      <Text>Watch it.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="fa2023c2-1417-44eb-8087-fa7788977373">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9336ed0c-6105-435f-abf5-686d88828562">
      <Text>It's up ninety-four, take a left on five-fifteen. Three, four miles. You'll see the old sign.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="b560029c-4ef6-4040-9f94-cc9cff28de7d">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="05094511-186a-4589-a950-c802afcc396c">
      <Text>Place has been closed since— God, when did they shut it? Nobody's been up there in years except kids breaking in.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fee5bc72-7b23-4d4e-afa8-ee25ebee6e23">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8be8b321-611b-40df-8d52-44652eb27d98">
      <Text>Yeah. I don't really know what I'm walking into.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="45d3330c-2651-4eb4-b5a0-f5a46a494369">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="f0b1ac4e-2176-401e-98c1-460a35d469af">
      <Text>(studying him again)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f66508e0-37d9-4b75-8ab4-0c8a181baf35">
      <Text>You walked here.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8dbb6ba6-6d09-4cde-9595-4fa1cdafd450">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3b510625-1b57-40d6-98d2-e3508d28acbd">
      <Text>Bus. From the city. Someone asked me to come.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="afdc985c-32c2-437e-9938-6b79b9786d10">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bf6cfd70-5a70-4077-ac2b-89ad77113b55">
      <Text>Must be some someone.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8ff3aa77-7d2c-4444-bd2b-0295195ea4c8">
      <Text>Chuckles doesn't answer that. His jaw does its thing.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f3c8a3e4-ee4c-4849-a80d-a95cfd049f87">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f4184e20-a983-4223-af5c-e780bce0089a">
      <Text>Can I bum a smoke?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="751087a4-2b7d-4efe-a2ae-7b51a979ce1f">
      <Text>Gladys reaches into her apron— shakes one loose from the pack. Holds it out. Produces a lighter. Lights it for him.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e8317e6e-fc37-4935-8e2b-d79264824822">
      <Text>He nods.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="57ee9ef6-d56d-4193-9409-e8d7d97776e5">
      <Text>CHUCKLES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2654bdf7-4702-4641-a8c6-aa4e3e529d55">
      <Text>Thanks.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5bb08e62-83a5-4366-a229-11e802926711">
      <Text>GLADYS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="65d9fc00-8d7f-479e-a22c-f25675e6742a">
      <Text>Four miles, sweetheart. On the left. If you hit the ski mountain you went too far.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d7954b42-94ef-49a5-b619-53b2f12da0c9">
      <Text>He starts walking. The duffel. The smoke.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="00e5c3ab-c46c-4f01-aa4b-8643e69f32b6">
      <SceneProperties Length="1 4/8" Page="43" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT — SUBTERRANEAN LOADING DOCK — DAY</Text>
    </Paragraph>
    <Paragraph Type="Action" id="877c6639-8e8e-4c4b-905f-4bdf9cf22c94">
      <Text>Concrete. Raw concrete everywhere— floor, walls, ceiling— the bones of the building with nothing decorative between you and them. Yellow safety railing running the ramp down from the service entrance. Light leaks in from under the exterior roll up truck access. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="877c6639-8e8e-4c4b-905f-4bdf9cf22c94">
      <Text>Conduit and pipe runs overhead in a dense canopy of infrastructure — electrical, water, gas, data — all of it labeled in stenciled letters.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bc0d4df1-e137-4398-9998-9343f433e522">
      <Text>A green dumpster. A forklift that hasn't moved in years.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="491dbca2-971e-4077-bf72-04e68208b597">
      <Text>Jamie moves past all of it. Deeper. Into the far corner where the conduit runs converge— every electrical line in the building tracing backward from its destination to this point, the way every river traces back to the mountain.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e43af315-56e4-491a-a737-12e1ca5b5a4d">
      <Text>The cage. Floor-to-ceiling wire mesh, industrial gauge, the kind of enclosure that says do not enter this space unless you are licensed and insured and have told someone where you are. Behind it— three transformers. Massive. Twice his height. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="ec689839-0ac7-4845-8794-4c8e5329fd81">
      <Text>The cage door is padlocked. The padlock is fine. The cage frame is not — the bottom corner has pulled from the concrete anchor, years of thermal cycling working the bolt loose, opening a gap between the mesh and the floor. A gap that a thin fourteen-year-old, turning sideways, exhaling, pressing his cheek to the concrete—</Text>
    </Paragraph>
    <Paragraph Type="Action" id="539fe2c7-0433-4e0a-a62a-8c9a0ef202ee">
      <Text>Can.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="43cc8a66-1bd1-4165-9110-3f2befbe946d">
      <Text>Jamie squeezes through. His hoodie catches on the mesh. He pulls it free. Stands.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="540bdb95-ff8a-4cb5-b0c9-643e8970b321">
      <Text>The air in here is different. Alive. The residual static charge in the air from three transformers and forty years of accumulated electromagnetic field sitting in a concrete box with no ventilation. His hair lifts. The fine hairs on his arms and the longer strands on his head rising gently away from his skin in every direction, reaching for something he can't see.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="756513b1-12c2-44d1-a4f5-f6e9e22debe2">
      <Text>He can hear it. The hum. The hum of potential. Sixty-hertz. The frequency of everything that makes a building breathe.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="947a848f-30c4-4d89-971c-4791186c9c9b">
      <Text>He is smiling. Ear to ear. The full unguarded grin of a kid who has just found the biggest puzzle he has ever been given and is about to turn it on.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0d9ef184-a3a3-45fa-97a1-36e406484d96">
      <Text>He reaches up. Both hands. The main scissor switch on the first transformer— a lever the length of his forearm, red-handled, heavy.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="93b5bc35-1c76-4191-b25a-11bcb274363d">
      <Text>He pulls it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4f614e26-6e18-42d3-848a-8d991e6f7911">
      <Text>The resistance. The mechanism arguing with decades of seized position. Then— chunk. The contact engaging. The transformer catching. A sound that starts in the housing and moves through the concrete floor into the soles of his sneakers and up through his skeleton.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="547026d7-0db9-4f72-bdd7-94d6ca00abb4">
      <Text>He steps to the second. Pulls.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cfac96a7-20f4-48d6-b729-fa0a0ed90d93">
      <Text>Chunk.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="aad2ead7-99ca-45f9-9741-edd128955277">
      <Text>The third. Both hands. The lever heavier than the others, or maybe his arms are tired, or maybe this one has been waiting longer.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7b484acc-41b3-4a0e-8520-3e19a287dbfe">
      <Text>CHUNK.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="dbc13620-dd16-4c11-91dd-94b9179685bf">
      <SceneProperties Length="3/8" Page="45" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT — VARIOUS — CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="224b7f78-3ade-49f1-9dc5-7b71e8810893">
      <Text>The lobby— the recessed fixtures in the balcony tiers fire in sequence, one floor at a time, climbing the atrium. The ferns throw shadows on the pink walls.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="031b11a7-15e2-47d8-b000-abfb0abb5035">
      <Text>The Sidewalk Café— the ceiling panels buzz and catch and the wrought iron lamps glow warm and the tree in the center is suddenly, impossibly green in real light.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7dd8e37a-c950-4f3b-929b-38e3b10876cf">
      <Text>The Cabaret— the 1970s lighting grid, the parquet floor, the stage— all of it flooding with light that hasn't been in this room since Reagan.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b1b3902b-335d-463a-a123-134ce96966ab">
      <Text>The Pool outside- underwater lights flicker up from the submerged lighting glowing the emerald green of the ancient jade.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="482eeb01-a295-4176-8750-cb3fcbfc066d">
      <SceneProperties Length="4/8" Page="45" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT — INTERIOR DINER — continuous</Text>
    </Paragraph>
    <Paragraph Type="Action" id="373c8d13-da8f-4a08-8811-055a7c830bd6">
      <Text>Hunter looks up from the legal pad as every can light in the ceiling comes on at once.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="bff7a5b2-2eb7-4f3a-bb67-73d232fc1f67">
      <Text>The diner is west of the lobby, third floor, tucked behind a corridor turn that makes it feel like a secret even though the signage is still on the wall. Lower ceiling than the rest of the building. Recessed can lights throwing warm circles onto the tables below.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f755a632-0883-4483-9230-107e5d6e9953">
      <Text>Gold leather booths— tufted, U-shaped— arranged in rows along the far wall. Mirrors behind them, smoky now, clouded to the point where they return the room as an impression rather than an image. Pedestal tables on chrome stems. Swivel chairs in matching mustard leather at counter-height bar tops running the center aisle. The carpet is mauve. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="b40ac8f7-ead3-4965-9573-79ad62f5a2a5">
      <Text>Hunter is in the far booth. Back to the wall. The Samsung face-down on the table in front of him. A legal pad beside it, pen uncapped, nothing written. He is sitting frozen in internal conflict.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="563e5aea-f119-45e1-a372-d4aa4ceb8752">
      <SceneProperties Length="5/8" Page="46" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. ROUTE 515 — VERNON TOWNSHIP — MORNING</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0638a921-176f-46e5-8611-bafd7c99f9df">
      <Text>Chuckles walking. The duffel. The cigarette Gladys gave him down to the filter. The road empty in both directions. No sidewalk. No shoulder worth the name. Just asphalt and trees and the particular quiet of a place that has been left alone long enough to forget it was ever anything else.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a0cba9bc-b3ba-4479-8ada-b7be46f668e0">
      <Text>He walks on the gravel edge. A car passes. Then nothing for a long time.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5d99d34b-d909-44e8-9fc5-21e181a7f3cd">
      <Text>His phone buzzes. He checks it. The pin drop, recalculating. 0.4 miles.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4bd5a730-40d8-4ba7-b266-061bf79668dd">
      <Text>He keeps walking.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8a00da7a-6ee1-45b0-afbf-4e65f66bf43a">
      <Text>The sign appears before the building does. A stone archway over the drive entrance — river rock and mortar, the kind of thing Hugh Hefner signed off on in 1971 because it looked regal on the architectural rendering and because no one was going to tell him it didn't. It must have been something once. It is now something that used to be something, which is a different thing entirely. The lettering across the top barely legible under thirty years of weather and vine — PLAYBOY RESORT AND COUNTRY CLUB.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a5a76b49-f2d1-4c32-8e2b-aefcc9b88ad7">
      <Text>He stops. Looks at the archway. Looks at his phone. Looks back at the archway.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c7c09742-34f1-4e49-991e-6fd254bd52b3">
      <Text>He pockets the phone. Walks through it.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="7a2432fe-d27d-4868-98df-6db14efa9e12">
      <SceneProperties Length="8 1/8" Page="46" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="HUNTER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEVIN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT — INTERIOR DINER — continuous</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e97409da-b14f-4618-a4fe-325dd03f6a7d">
      <Text>Kevin appears at the entrance. Stops. Reads the room. Crosses the diner to where Hunter sits alone. His shoes on the brick tile walkway between the carpet sections, then onto the mauve.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0be44be6-ceb3-4702-97e2-3c6fec398903">
      <Text>He slides into the opposite curve of the booth. The leather takes him with a sound like an exhale.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="93a251eb-b8be-45db-935b-8619375981f9">
      <Text>Hunter doesn't look up.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fca43a9a-9fab-495d-8b0f-3784fd1c8f52">
      <Text>Kevin looks at the phone on the table. Looks at Hunter.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d3675305-46c8-4a2c-8446-82e52bf6085f">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2acf8320-b749-46bc-a9ef-c8e38f119a0d">
      <Text>Let’s talk divorce.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c7706f26-1db5-43b4-9dd8-e8d7c6d9eb2b">
      <Text>Hunter's hand comes up. The hand that means stop.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6449b8d4-1f6d-4215-b793-9e41a595f4e0">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fe706c0b-cdd5-4b0f-9f83-6004dcd3bcb0">
      <Text>Don't.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="05cd9aaf-140a-4e92-8a8f-03e9a231206d">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b761481f-b23b-48e6-8b0b-900faf493361">
      <Text>I'm telling you as my attorney that I want—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1c3c8987-3b57-4fd2-b162-2706913195f0">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e67a32e0-32e3-4ecb-9943-20e5cad44b17">
      <Text>And I'm telling you as your attorney to shut the fuck up!</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0e49b829-0aec-4fdf-969c-782f5b233337">
      <Text>Kevin stops.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d28730ab-43b0-4e1c-a595-9ebe1fc2738b">
      <Text>Hunter picks up the Samsung. Turns off the light. Sets it back down. Picks it up again.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a816d015-5c92-4d2d-b672-e12fd2311a21">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bb2cf06e-6cb2-4f53-87db-98461bfef9e0">
      <Text>What did you see. In the car. On the phone. Specifically.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="04216bfa-5393-4b81-91a1-c034c3812f5a">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ee3212e4-eb06-4002-bde3-d3c942d7a2f6">
      <Text>Enough.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="511e67a8-4066-41d6-aca7-36fe9c1f1fa1">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4714e3e0-cd02-44c4-9ab9-b89ea71e8036">
      <Text>I need you to tell me what you saw so I know what you actually know versus what I now know versus what we both know, because those are three different legal categories and right now I cannot afford to confuse them.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="49cd4fcc-97e3-4998-b13a-64e15ba48b7c">
      <Text>Kevin looks at the table.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="29d4648a-abcc-4f85-80ff-b35b07682df8">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7d6c3a6-f887-49e0-a196-f8cf6360d08a">
      <Text>I saw a photograph from Chet Masters to my wife. Of his— of him and his face.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d1387cc6-cfd3-48e4-a8fc-6c1d0331492e">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6f585a10-4621-48c7-b90f-1b196a2bc789">
      <Text>Okay. What else?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="173fa8e5-d62b-44b3-acf2-4a74fe4d2fce">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="69248bbe-748d-4ace-b48c-dc3121fa6dc0">
      <Text>And I saw the message before it. Intimate. It was about a recent act-</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="89059610-6f18-42f9-b918-24e5052281cf">
      <Text>(deep breath)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="33791ae0-a8cf-42e3-8532-121bc6f7e318">
      <Text>It mentioned last Tuesday. And I handed the phone to Janet because shit kept coming and the kids were in the car.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b4f731d2-34c4-4a2b-9a2c-38f6cd690048">
      <Text>Hunter nods. Slowly.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="239dfadc-a69b-47bf-ba51-647f7f6d666e">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0c94cfc3-6501-41e7-b98a-586bdad5fdb2">
      <Text>Ok. Here's the issue.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a995984f-c6a8-42e5-9f93-8ec82adeb028">
      <Text>He thumbs the Samsung. Scrolls. The scroll takes a long time.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1401c75a-3b34-42a9-b116-918170b4fd2c">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4490e88c-e2ec-4a2b-9d78-f7bb150366fb">
      <Text>When Jamie put </Text>
      <Text Style="Italic">MY</Text>
      <Text> phone on your family plan, it pulled everything. Your wife's entire message history synced to this device. I don't know how far back it goes. I stopped scrolling. There are messages. There are photographs. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="261a7ac4-e079-45b6-8923-e81e504aeca3">
      <Text>He pauses.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f4d25641-73f6-4e21-b32b-126efe4a9daf">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3656d613-b1a9-4bc5-99dc-6da3286ccd3c">
      <Text>Kevin, this is not just a recent thing. This is not a one time a lapse or a— </Text>
    </Paragraph>
    <Paragraph Type="Character" id="d411d67f-4a0d-4e01-98db-d5c0b4b1a9c5">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="844e610a-1b21-4b3d-b38a-dec68254da43">
      <Text>How long.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="774856b7-63d8-4af9-ac8e-84bc0f46284c">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a7ae7665-f5b9-48b3-b82a-654b62660add">
      <Text>I don't know. Long. Longer than matters for the point I'm about to make.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2c22f4ea-88ea-4230-9bab-ec7058d3fef6">
      <Text>Kevin takes a deep breath, holds it for an extra beat.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3261273d-65d8-48ef-9871-4ba186634344">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="91e95bb5-5f1a-4e25-9353-ac012d662ff5">
      <Text>Then you understand why I want to talk about my options.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f4eb38ab-6048-45e5-9194-bc5284dddc17">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="425772a2-4da9-4b32-b183-4313a8aef192">
      <Text>I understand. Here's why you can't talk about it. Not right now. Not yet. Maybe not for a while.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="4cd0e83c-b71a-48ee-8551-98e7122d6415">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c60283c3-6a97-471c-821b-9e1e487cf28b">
      <Text>We both now know she's been sleeping with at least Chet Masters. And he happens to be currently working with the A.D’s office to help prosecute you for securities fraud. The man who retained outside counsel against you the morning of your arrest before you'd made a phone call.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="0467c833-81bb-4b2e-8739-de358873c3d4">
      <Text>He leans forward.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="042a5b04-15fe-4364-86ba-f1c09cab74b9">
      <Text>Kevin’s hands are going white from their pressure on the table in front of him.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0c9db2c0-173d-49d5-b36a-bcd7da6606d3">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="753336cc-5d25-4c77-ba32-dc7464b867e6">
      <Text>At least Chet?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="432e3880-c9ab-45fd-b587-60717cab6125">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d2c5ec48-618b-42dd-ac9c-28bee1b39591">
      <Text>Yes, and you cannot act on it. You cannot say the word divorce to your wife. You cannot say the word Chet to your wife. You cannot say the word phone to your wife. And here is why.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="612386a7-15a3-497d-bb9c-da2d5262dee2">
      <Text>He picks up the legal pad. Starts writing as he talks— it’s the habit of a man who thinks through his hands.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5eb3983f-3a4a-47dc-b7b2-da44b327a120">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9e7db243-a1e8-4041-ba13-648969a4fc96">
      <Text>Step one. You tell Janet you want a divorce. She tells her lawyer, maybe she tells the court, the prosecutor- her lawyer certainly will tell them. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="9d7d89f3-0b08-4d2a-9750-aeb427930176">
      <Text>(he take a breath)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9e7db243-a1e8-4041-ba13-648969a4fc96">
      <Text>Anyone asks you why. Now you're in it. You say infidelity. Someone- anyone asks how you know? Now you have to explain that you saw a photograph on a phone in the back of a car on the drive up here— a phone that you picked up and used- which is a device violation of your pretrial conditions because you did not pre-disclose that device to Pruitt. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="f6e814bc-d76f-4aee-951f-5068d25f7882">
      <Text>(ramping up)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9e7db243-a1e8-4041-ba13-648969a4fc96">
      <Text>You didn't know it was active. Doesn't matter. You touched it. You used it. You did not report it. That is a violation. Pruitt finds out about that, you are back to jail to wait to stand front of a judge.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9bcf81f8-16a9-4e6f-8ea0-c33d4f937eb2">
      <Text>Kevin opens his mouth.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aed37386-0642-4dd0-9d30-39208dcfb3ef">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f87b6150-f77f-4d1e-9627-69562afae004">
      <Text>I'm not done. Step two. That phone— the one you touched, the one you violated your conditions with— synced your wife's communications to my device. To your attorney's device. Which means your wife's personal messages, including photographic evidence of a sexual relationship with a man who is a material witness in the prosecution's case against you, are now sitting on the phone of opposing co-defendant's counsel. Me. At a time when your wife was unrepresented. No lawyer. No privilege. Nothing protecting any of it. If anyone asks any of this there is no attorney client privilege- you and me can be compelled to testify to this.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2043579c-69f9-4445-8514-95a655c7f1bd">
      <Text>He underlines something on the legal pad. Hard.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ab028d99-9e91-41b3-a563-ded5d47a6940">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dd282346-b2af-498e-8200-942c8a42ff2b">
      <Text>So I disclose the sync— which I am ethically required to do, eventually— I have to explain how it happened. Jamie's </Text>
      <Text AdornmentStyle="-1">IMEI</Text>
      <Text> swap. Your device violation. The fact that I have been in possession of a co-defendant's private communications with a material witness for— how long has it been now— going on 12 hours without reporting it. This is the kind of thing that gets attorneys disbarred, Kevin. Not sanctioned. Not reprimanded. Disbarred. Career over. And if I go, your defense goes with me, because everything I've touched from this point forward is contaminated.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="45e841bf-c9e6-4064-94d4-550c1da57a21">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1fef4709-fd50-4f39-a389-cb6b88f4233f">
      <Text>So don't disclose it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="86a49441-c86c-4da2-999d-e6aafe648310">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="71e85fcd-ccf9-4c07-be39-26bbfe598232">
      <Text>That's worse. Any competent A.D.A is going to do a carrier records pull during evidence collection. Standard procedure. They subpoena the device history on everyone connected to the case. They will see the </Text>
      <Text AdornmentStyle="-1">IMEI</Text>
      <Text> registration event. They will see the timestamp. They will see which devices received the sync. And then they will have me for a discovery violation on top of the ethics violation, and they will have you and her for pretrial release violation that you concealed, and they will have Janet for receiving communications from a material witness for the prosecution while she was a co-defendant under contact restrictions.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7c21becc-67be-44db-a846-e224cd06447f">
      <Text>He puts the pen down.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="21138653-5778-49ed-ab3c-6fe16c2f3dfb">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0fed91ec-c7d1-410d-a627-757314b1c976">
      <Text>So. You tell Janet you want a divorce. The A.D.A ask why and how you know about Chet. Jamie’s actions are not protected by privilege, the explanation requires you to disclose the phone. The phone leads to the sync. The sync leads to my disbarment and both your bail revocation and both of your violation hearing. Your son gets pulled into a federal telecommunications fraud investigation maybe. Your daughter's custody of Jamie gets challenged. Everything— every single thing we are trying to hold together in this building— falls apart. Because you said the word divorce to your wife.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b8544924-78b4-4cef-b72a-4d8c10c404a2">
      <Text>The diner sits quietly around them. The can lights. The smoky mirrors. The ivy.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1faeb144-c678-4b9a-8d21-42917f672962">
      <Text>Kevin is looking at his hands on the table.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="77f9e7cc-2999-4343-8b6f-25c428beced4">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bdc45dd3-a2c5-4cb7-86eb-143e5cd62b10">
      <Text>So I just— sit here. And look at her. And know what I know. And say nothing.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f6051ec6-dd93-4d4b-9100-417dfafd90f8">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="81af7f35-9b9c-4f9d-9446-b108a4e2f4b3">
      <Text>Yes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="83b9af93-01e4-496d-893f-c13552ccca7b">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3409f15c-45d3-4498-9776-95bb6c546877">
      <Text>For how long.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a3b1ad38-3200-4a02-87fb-a0a0a971b57a">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6e2abdd4-725c-43f9-b8e8-be6c3f417d06">
      <Text>Until I figure out a disclosure strategy that doesn't destroy all of us. I don't know how long that takes. I don't know how big the window is before the records get pulled.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="58235457-d822-4fbb-9a0c-a45ac6ac8b76">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6095e0a4-fe3a-4f47-bd60-792975d33169">
      <Text>And in the meantime, what. I just pretend.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="001e414d-20c6-4245-be46-15eb3bc30aed">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="807dfe51-f1ba-4987-b06e-6ea70727c814">
      <Text>You've been pretending for twenty-two years. You just can’t lie to yourself about it anymore.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e9fc8182-e50f-4bb3-bd9b-73214b93eb3b">
      <Text>It lands. Hard.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="98b687cd-2e26-4e30-82bc-87cdca6669f6">
      <Text>Kevin's jaw works.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f9d9da37-a698-406b-87bf-8b83f381b0a2">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b86d400f-1b7f-4ce7-9899-a42fde5ed8cb">
      <Text>That's a shitty thing to say to me right now.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f43139eb-8207-49ec-b531-6fe516391285">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6cef8da6-8d1a-41d0-8617-a52b7859bdc7">
      <Text>Yeah. It is.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="b2c92e03-cad7-4b14-986d-333bd38ccb88">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="65c6ba0c-bc48-424e-8820-090a67a6b2ac">
      <Text>It's also true.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2b6fd275-5b5b-4795-ae84-3b14fa1d9aec">
      <Text>Kevin doesn't answer. He looks at the mirror behind Hunter's head. At whatever version of himself reflects back— smudged, indistinct, the outline of a man who is trying to locate himself.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dd282ac0-1f6d-44c9-bb1d-0b052800760e">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="15494cbc-3e4b-4b61-b3df-03ec41d947f7">
      <Text>I trusted him. He was the best man at my wedding. He was there when Jaz was born. He—</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e0aa82ae-e87f-4e4a-8401-3ef81ba4c3aa">
      <Text>(voice cracking)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ef3a9021-dbee-4c20-84ed-f63efd861f72">
      <Text>How much of the last twenty-five years was real. Any of it?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="aaf58d28-0f2e-4ccd-841b-9c61edf80c17">
      <Text>Hunter looks at him. Watching the weight of Kevin’s own blindness crush him. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="d00195b1-7318-4e2c-872d-14be7c9757cb">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d90a957e-7edb-416a-a3cb-243cea4841f7">
      <Text>I don't know.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="33de3281-3c9a-4e6f-aa79-a13d04fe4d85">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e3338ded-7b62-41d0-9f6f-312c8524cd78">
      <Text>What else has been happening in my own house that I—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d8ef5d9d-55ec-4069-9f54-10411e8b13d4">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e7be1dd4-b823-4543-8e0b-09759ff01326">
      <Text>Kevin.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="20ba30a5-9846-457a-b6b1-774c79058541">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1ec025f5-0a52-419a-80dc-7da6080d1370">
      <Text>My daughter. My son- I thought I was showing up.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9b5584f1-90a4-4c2f-98f9-4fdfd5d5e45e">
      <Text>Hunter give him the space. this is not his place, but he just can’t help it.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bfcfc7cb-10e8-466e-bed8-a931e2dbc3bd">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e0ec4c32-f7fe-4884-b820-5b4ce4d92274">
      <Text>Can I say something that isn't legal advice.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7d1737aa-be58-4241-bf65-a2d6a95733e0">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1b4538af-6352-45dd-9ae6-397a644cb545">
      <Text>At this point I'll take anything.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dc9fc57a-2b83-4556-8a83-3071df701419">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cdb4c607-2054-4bbd-ac1d-a575cf5629d6">
      <Text>Your daughter dragged this family out of a federal arrest, bailed three people out of custody with cash she won at a poker table, acquired a seven-hundred-thousand-square-foot building through means I'm not going to examine too closely. She did that in fourteen hours. She's eighteen.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9239cad5-556a-40f1-97e4-518fb9f6ba60">
      <Text>Kevin looks at him.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0a0a2ade-a51c-49f0-8cae-e5cfc6ed643c">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4e4ea5f1-55cb-4bb3-84e7-5f05d686a2d2">
      <Text>She came from somewhere. From you and from Janet. Whatever you two are— whatever this marriage has been underneath— it produced that.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="24dfeca7-18f2-4da3-b6c3-81aab826af78">
      <Text>A beat.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1d368ced-a86b-4fcb-ab53-4faadfa1cd97">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f56c637a-131e-4dc7-b059-944a95d4570b">
      <Text>So maybe you don't know your wife. Maybe you don't know your kids. Maybe you don't know Chet and maybe you never did. But something in that house— something in the two of you together— made Jaz, and Jamie. And if I'm being honest with you, which I apparently am now, she is the reason I'm sitting in this booth instead of on a bus back to the city. Not you. Not the case. Her. Because anyone who can do what she did without so much as a blink is something worth saving, even if the people who made her don't know her yet.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ba960c79-19d2-4a69-bb2f-6de6c09a72be">
      <Text>Kevin is very still.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="88d574bb-f372-42b9-8d97-d8bccb52f407">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3b120f6f-e64a-4319-8b98-85035915ed63">
      <Text>You've known us for twelve hours.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="642ede18-aeab-4eeb-9987-a0f33c906252">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="71df13cd-263d-472c-a8c9-4b7b929a2670">
      <Text>Longest twelve hours of my life.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="9731801c-7c64-4628-9f08-ac6288404602">
      <Text>Something moves in Kevin's face. Not a smile. The muscle memory of where a smile would go if the circumstances permitted one.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7bbc31ce-b020-4a86-b018-eddad17716be">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6e1b7c6e-81cd-46f6-b1fb-cb7e3f2fc629">
      <Text>So I can't talk to my wife.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="650749e0-284f-4fe7-93d1-daf38125c808">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e74adf13-4327-4e01-9e16-ccdb9bcd6e76">
      <Text>No.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="276c6999-c906-46cb-a0bc-a5a4a26723a9">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9f172bb7-c19c-4687-b1a0-c11f99d8beb8">
      <Text>I can't tell Chet to go fuck himself.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1662638e-ba65-4c70-b506-ac700cade0be">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b809465d-a7c5-4c04-b313-af39475de5b6">
      <Text>Especially not that. Contact restriction. Both directions.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="85e5e27a-5123-439d-a03d-6ed9ae540868">
      <Text>Kevin looks at him.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c249d5ea-0385-46ce-a7e7-5543d1dea50b">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b34a35a2-7675-4e4c-a84a-9b87c953ad50">
      <Text>You want me to pretend that everything is fine.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a219d165-f024-47ff-a572-cf1786912100">
      <Text>HUNTER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7ae5ef61-a9f6-466c-92a1-72ab2e302598">
      <Text>I want you to do what you've always done. The only difference is you know it’s bullshit now.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cf0fb075-95c4-4899-8579-a4ee24082a34">
      <Text>Kevin stands. Slowly. The leather releasing him.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e114d16f-528c-4de2-bfae-d6b547912712">
      <Text>He looks down at Hunter in the booth. At the legal pad with nothing written on it. At the Samsung that is quietly, methodically, ticking toward both of their destructions.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="dd193b20-64ff-454b-b399-74a3fa83a1f6">
      <Text>So this follows directly from Kevin standing up in the diner booth — Hunter just detonated his entire marriage and told him he can't do a single thing about it. He walks. He needs to find someone. And the person he finds is the person Hunter just told him he doesn't know.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="e14c7dfb-3135-472c-9c78-a31e45ac2801">
      <SceneProperties Length="2/8" Page="55" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT — CORRIDOR — DAY</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e99f7df2-46f3-4c2a-a853-ebbe337fee8b">
      <Text>Kevin walking the corridor with the aimlessness of someone who has just had everything he know ripped away from him.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5e047bba-b8b5-4248-bd89-1f6835368a8f">
      <Text>The overhead fluorescents mostly dead— one in four still working, throwing pale pools on the floor at intervals that make the walk feel metered. Like a pulse.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="848d6b17-44db-4422-96b0-9edf40c5bd41">
      <Text>A sound. Faint. Music— but not from a speaker. From a big space. A reverb that is the acoustics of concrete and volume and emptiness. He follows it.</Text>
    </Paragraph>
    <Paragraph Type="Scene Heading" id="7578ef5a-64ae-4063-9bdb-1f608739dcb8">
      <SceneProperties Length="5 3/8" Page="55" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JAZ">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEVIN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. PLAYBOY RESORT — INDOOR POOL — CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action" id="100f1275-553f-410a-885c-b0f126f9b626">
      <Text>The doors are propped open with a cinder block. The room beyond is enormous and wrong.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="8c8961c7-21e6-48fe-811b-75d4a31c5d22">
      <Text>A half-Olympic pool. Empty. Drained years ago. The basin drops eight feet to a floor of rust stained concrete.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="63aa972a-3894-49b4-af9f-7a992772dfff">
      <Text>The ceiling is dark wood at harsh angles— Morning light comes through the far glass wall in shafts that land on the basin floor like spotlights on an empty stage.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b178aee3-1f3f-4dcd-b1d4-637ec0ccfa9b">
      <Text>JAZ is at the bottom.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="024ef842-dbea-4d2a-8bfd-7f3789b6e8cf">
      <Text>She's sitting cross-legged on the pool floor, dead center. Her phone propped against a little bluetooth speaker. The music spilling out it— something loud and shredded and beautiful at a volume the speaker can barely handle— bouncing off the concrete basin and the glass walls and coming back as something cathedral.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f0592842-8b83-4ff6-bb7f-f6c0b9da049b">
      <Text>She's not doing anything. She's just sitting in it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3f8477c5-b50a-4306-957b-1af3a352a807">
      <Text>Kevin stands at the pool's edge. Looking down at his daughter on the worst morning of his life.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="26858cf6-a070-4bd0-bc82-fab9d36422e7">
      <Text>She looks up. Sees him. Doesn't startle, just waits for a long moment for him to absorb before she reaches over. Turns the music down. Not off.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6940602a-c83a-46c8-90f1-95e9c4ae14da">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="73a473b4-0968-4281-89c7-ac1b7cca99f4">
      <Text>You look like shit, Dad.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5ae1b681-81e6-4fef-b2cb-5316f5938bbf">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="fa5cf3bd-7fb2-4571-bebc-f79d21013709">
      <Text>(looking down)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="40eec501-e9ec-47ae-9100-41c00183a656">
      <Text>Thank you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="49c13335-4326-4411-82da-7637031cd7f0">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="28f9e8d6-cfa6-4773-bbf9-eb0109fafb35">
      <Text>There's a ladder at the shallow end. If you want.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="127bdc55-40bd-4091-9780-b7575283e542">
      <Text>He looks at the ladder. The shallow end slopes to maybe three feet of depth before it drops to the basin floor.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7fdaa5f3-ecd8-49c8-9608-7615eb37cc65">
      <Text>He goes to it. Climbs down. His dress shoes on the pale blue tile, the sound of each step enormous in the space. </Text>
    </Paragraph>
    <Paragraph Type="Action" id="c134953b-5206-4a58-ab46-0286866b0408">
      <Text>He sits down. Cross-legged. Across from her.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="875741a1-0aca-4a55-8c7b-3fba00c98714">
      <Text>The music between them. The light through the glass wall moving across the basin as a cloud passes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7198c68e-19ba-4db5-b357-0107e439b1f0">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="df62c60d-1417-43e7-bbe9-198ea7df073e">
      <Text>What are you listening to.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="de7d6bb4-c1a3-4707-a918-b109288adbf3">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="800694eb-6181-4770-979f-20cf58844e86">
      <Text>Amyl and the Sniffers.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8c11d2b7-caca-4b78-aea2-c6ce4fd6d6cc">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="f5dfd9a2-66bc-4e9f-9c81-95e4ecfce73e">
      <Text>(no recognition whatsoever)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="48972e47-1a8c-4e38-9145-d3400dd20ce7">
      <Text>Okay.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b88a6f08-90b8-41cd-ad0e-b1a83d5634f4">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8f7c1cb6-dc09-46fc-a4ea-770eaa54b05c">
      <Text>Australian punk. You'd hate it.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2b383971-9662-497d-8bc3-da5009dda81e">
      <Text>She shows him the full riot girl album cover on her phone.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5bf87384-027b-467d-98e0-183624a88c55">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="f5b81abb-1fcd-4336-a219-b354af1c937d">
      <Text>(a beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d2885886-93cd-4db0-97ce-d2de9f6a7a0c">
      <Text>Probably.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="1259329c-874b-498c-8124-86debdbb0ed6">
      <Text>He looks at the basin around them. At the light. Jaz just watches him absorb this new reality that she is so comfortable in.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b928e844-543a-47ce-86e3-e101f855e40a">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ce793bff-582b-484a-b12a-e6cb2c7f3e4a">
      <Text>Ask me something.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4fd51a08-f75b-4176-b9f6-761ad4aada2f">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6bc2e0ba-f455-46aa-80c8-120c258a9f08">
      <Text>What?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="32ca46f2-d883-4a72-94be-b2d121f055cf">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e3e4dcb5-10bd-4435-92e1-4062207962ef">
      <Text>Your whole life just caught fire. So maybe your path forward is to start to ask people about things rather then assuming your assumptions are right? I’m right here, dad. me. It’s ok. If you want to know me, you can ask me about me.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="554a5138-87e3-4073-8e6d-b9b227fcf31f">
      <Text>Kevin looks at her. Really looks. Maybe for the first time in the way that looking requires you to not already know what you're going to see.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d2d4a9c4-d503-47fa-a258-84017def6661">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="ab2ed977-6870-468f-a41c-888c3b11a85f">
      <Text>(carefully)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ed16dbb7-5601-4a82-af60-0495034762c6">
      <Text>Who are you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4473063c-bc64-497b-8dfd-3269195ac135">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="113ba90a-18fc-4819-8a46-baa0bc6976c4">
      <Text>(a small smile — the mischief, right there at the edge)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="57a012ce-1fac-4c2c-94c3-84ce7dc7b7af">
      <Text>Okay. Right for the jugular, huh? That's a big one. You want the version you can handle or the version that's true?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3d48fc5b-1f3f-4738-b04d-7317995b5543">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fc73e892-2ff5-40d1-87a1-bccb81897c75">
      <Text>Do I get a choice anymore?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="43998496-c9a1-4d94-ba6a-965e0e84a502">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b0070b4f-ce81-487b-a3a3-527819832eae">
      <Text>No. You don't.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="568456a1-e4f3-405c-a33c-e89b5d38d4d7">
      <Text>She pulls the flip of her hair back. Underneath: the shaved side. The tattoo work trailing from behind her ear back into her hairline— fine line, intricate, older than he would have guessed.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7bff2343-0ec3-4545-bda8-1d0c86a99e97">
      <Text>Kevin stares. Reaches out, hesitates, then rubs the shaved stubble as she leans into his touch.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a4da10c3-9186-4edc-b301-c820789f41b8">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9486bafd-fbd6-4e60-888b-81ea9727d9e3">
      <Text>That's been there since I was sixteen. The hair, longer than that. I wore clips to cover it for you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="edf61d8f-5d7a-42a4-bdf4-732d877e3938">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="816f6e97-7471-4ae9-9132-24f9f857a451">
      <Text>(processing)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a47e1412-ed85-42d2-b6be-a3e79a404c54">
      <Text>For me.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9741d86f-ad55-46df-af48-3cfa9dea8fe9">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5ec18a61-92fc-461b-b869-bef402e6d408">
      <Text>Because you always seemed happier not knowing. And I loved you enough to not peel away your happiness.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7243b536-3e91-4fdd-935d-423b230a0684">
      <Text>It lands in the empty pool and echoes off every surface in the room.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5b7b2e0b-e06f-4eb8-bfad-e97a24892006">
      <Text>Kevin's mouth opens. Closes. Opens.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4c44f066-70ce-4d60-bff3-35bc2ba28fd0">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ef7cee36-754d-410b-8f0d-ab267ef591e8">
      <Text>Jaz—</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7592b1af-cb9f-4628-b95c-4b583f68e4f9">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c77f71c3-68b0-4583-8615-894a48015228">
      <Text>My name is Phoenix. In every room I've ever walked into that wasn't in your house, my name is Phoenix. That's what the scene knows me as. That's what the pit knows me as. That's what every bouncer and bartender and poker dealer from the Bowery to </Text>
      <Text AdornmentStyle="-1">Bushwick</Text>
      <Text> has called me since I was fourteen years old with a fake ID that nobody believed or gave a fuck about.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="38ef21e2-9f0a-4c6e-9ce5-2a66b7694203">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="57cb395c-9ae2-4666-9bb8-a2daac0fc458">
      <Text>(very still)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5bf10ccc-771d-4a80-8e97-94d4d962493a">
      <Text>Fourteen.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8c5b754d-a19b-44ab-9e96-868d13c3db14">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3d990f78-dca0-44d5-8a5b-bdd7e7c54e8a">
      <Text>I've been going to shows since I was fourteen, Dad. Punk shows. Basement shows. Warehouse shows in </Text>
      <Text AdornmentStyle="-1">Gowanus</Text>
      <Text> where the floor is wet and you don't ask why. I've been crowd surfing and stage diving and—</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7f6053a6-1726-44e1-861e-9b0f0cf0392b">
      <Text>(pausing to let it settle)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="53243649-d4ea-4340-acd4-573a8b8485d3">
      <Text>I've been living a life. A real one. A whole happy one. Just not in front of you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1324b732-b3ae-4e80-8587-d550615eb79c">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6ef4897d-88d5-450b-8d6a-68cea9278dd7">
      <Text>Why?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4a920f96-b224-42c8-bf4d-4aba02704987">
      <Text>She pauses. This is the honest part. The part that isn't mischief.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e9c8710c-887e-4e6b-b924-0a7ba5a436b2">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2166a328-7c0d-47a3-bb8e-d39e0c18cca7">
      <Text>Because I looked at you and Mom across that dinner table every night of my life and I saw two people who had built a very careful house out of not knowing each other or anyone around them. And it seemed to make you so happy. It seemed to be what you both needed or at least really wanted. And I wasn't going to be the one to kick the wall in.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="1cd556ca-4bb5-4bec-b194-9f3dd3f04d7c">
      <Text>(retrospective)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d61ccce5-c2c7-42cd-9545-6af6580a86e0">
      <Text>I used to think it was brave. I thought I was protecting you. But I was also just— it was easier. Easier to be Phoenix out there and Jazmine in here.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fcb87617-3a12-4aff-b6eb-520b52a043d2">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7682264c-5d2a-43de-8f33-7c204f62efc6">
      <Text>(his voice thick)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bdf45c43-9757-4c91-b8d7-42d675733e43">
      <Text>And now?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="791b95fb-c85d-4a26-95b6-4bb68aa48de3">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="e69cc12d-8a5a-409a-906c-473564daf9ea">
      <Text>(looking around the pool)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1d94a4c7-cfe4-4e8c-a38d-742704fe870a">
      <Text>Now we're sitting in a swimming pool in a building I won in a poker game. You're wearing an ankle monitor. And your pretrial officer is a vindictive little man who is trying to cuckold you.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="7fee7e9b-cef7-41de-a22f-b03453d1c045">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="15e23683-fdf8-4b4a-95d8-fbd8346de50b">
      <Text>I don't think the careful house is available anymore, Dad.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7af26f89-f36e-40e0-819e-ce211ffde601">
      <Text>Kevin almost laughs. It comes out as something closer to a sound a person makes when the last wall comes down and what's behind it is not rubble. It's air.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fbc9794c-cb45-437f-84ec-1fce5c636e54">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d52dbac3-6bdb-4d79-9486-1a77c2040cf2">
      <Text>A poker game, Huh?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c8244852-0d67-45f5-9edf-b44039a2f5ba">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4251c577-60c8-4ca4-b23b-bd6b2115cb8f">
      <Text>Yes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e1bff178-6772-4220-82c5-2592f19f2d47">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5a9d7da6-1be3-4419-a884-4c60dbd9b9a1">
      <Text>What was the bet.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="93fc2e1c-da15-42d1-8331-e2c772dc3db7">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="9a1e9a0d-618b-48b0-bda0-91b16633b654">
      <Text>(the look — direct, calm, absolute)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="98545e46-9039-4916-bd2f-236e575ed7c3">
      <Text>You don't want to know what the bet was. What you want to know is whether I'm okay. And the answer is yes. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="d1a6fd1a-7f15-48f1-a10f-450abe1f3b58">
      <Text>(she let’s him take this in)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="98545e46-9039-4916-bd2f-236e575ed7c3">
      <Text>I have always been okay. I have been okay in rooms you can't imagine and I have been okay because I am very, very good at knowing what's real to people and what they truly want, especially the parts they won’t say— </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="41733fdc-2154-4228-b718-e10f80fe566f">
      <Text>(deep breath)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="98545e46-9039-4916-bd2f-236e575ed7c3">
      <Text>And now I have a real question for you that I need you to say- because even if you didn’t understand it before, this is actually a choice for you.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="26c85c2b-3671-4243-b4f5-a83e8b3c40a1">
      <Text>(with that phoenix fire </Text>
      <Text>burning</Text>
      <Text> behind her eyes)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="98545e46-9039-4916-bd2f-236e575ed7c3">
      <Text>Do you think you can find happiness being- my dad? Or is the Jazmine mask the only thing that you can be happy with?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7e9d3818-891d-4236-846d-18b1d8a86826">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="b6a2c6f5-4be6-4798-ba36-e2b63379f529">
      <Text>(wrecked)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d4912ae5-3f69-4405-8dfa-3385a13b8425">
      <Text>Jaz.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f9b0ec76-db08-457f-9722-27c60ea1cca6">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d06b1a45-4d18-4a76-a06f-7f16a8a610f9">
      <Text>Phoenix.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="df988e20-a9cb-4b88-8698-b1d1fcfaff14">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="fbe74b2a-9bb1-4bd1-aaa0-77907706ac98">
      <Text>(a beat — the adjustment happening in real time, visible, costly)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="692a19c3-cc7c-4fe0-85ba-6a67451d94d2">
      <Text>I- I think- I want to be Phoenix’s dad. Yes.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a1a88be8-b208-40be-8b7f-a54580e85a59">
      <Text>She smiles. Not the mischief. Something deeper. Something that has been waiting for him to say that name for a very long time.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="69efdc24-57da-450c-95a7-ae7271aa4312">
      <Text>JAZ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e2a0e726-9c38-4e36-9951-5cc17e371e97">
      <Text>Hi Dad. It’s nice to meet you. I love you.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e211d0c7-8108-4d3c-9e98-aa81cdf2805b">
      <Text>KEVIN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical" id="04fff0b9-7f1c-46c8-a91b-7dc8e21e6b6b">
      <Text>(barely holding)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="87dc228d-2d66-491a-8d04-36abef389f6e">
      <Text>Hi. I- I love you too.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="ea9fce0c-c625-4e32-8bb5-c36ba67c1eb2">
      <Text>The music plays. Amyl and the Sniffers, shredding, in an empty pool in a dead hotel in New Jersey. The light moves across the basin floor.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="169f229a-0505-494f-b79a-9da61f2959d5">
      <Text>Cut to BLACK:</Text>
    </Paragraph>
    <Paragraph Type="End of Act" id="99439383-c347-4636-83f1-8eae566f3c8c">
      <Text>End of episode</Text>
    </Paragraph>
  </Content>

